{{ 'tmolecule-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'tmolecule-product.js' | asset_url }}" defer></script>

<div class="tm-page">
  <div class="tm-buybox-wrap">
    <section class="tm-buybox">
      {%- assign featured = product.featured_media -%}
      <div class="tm-buybox__gallery {% if product.media.size <= 1 %}tm-buybox__gallery--single{% endif %}" data-tm-gallery>
        {%- if product.media.size > 1 -%}
          <div class="tm-buybox__thumbs">
            {%- for media in product.media limit: 5 -%}
              <img data-tm-thumb
                   class="{% if forloop.first %}is-active{% endif %}"
                   src="{{ media | image_url: width: 160 }}"
                   data-full="{{ media | image_url: width: 1400 }}"
                   alt="{{ media.alt | escape }}"
                   width="80" height="80" loading="lazy">
            {%- endfor -%}
          </div>
        {%- endif -%}
        <div class="tm-buybox__hero">
          {%- if featured -%}
            <img data-tm-hero
                 src="{{ featured | image_url: width: 1400 }}"
                 alt="{{ featured.alt | escape | default: product.title }}"
                 loading="eager">
          {%- endif -%}
        </div>
      </div>

      <div class="tm-buybox__info">
        {%- if section.settings.label != blank -%}<p class="tm-new">{{ section.settings.label }}</p>{%- endif -%}
        <h1>{{ product.title }}</h1>
        {%- if section.settings.subheadline != blank -%}<p class="tm-sub">{{ section.settings.subheadline }}</p>{%- endif -%}

        {%- if section.settings.show_rating -%}
          <div class="tm-rating"><span class="tm-stars">★★★★★</span> {{ section.settings.rating_text | default: '4.8 · 216 reviews' }}</div>
        {%- endif -%}

        {%- assign bullets = section.settings.bullets | split: '|' -%}
        {%- if bullets.size > 0 -%}
          <ul class="tm-buybox__bullets">
            {%- for b in bullets -%}
              <li>{{ b | strip }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {% form 'product', product, class: 'sans', novalidate: 'novalidate' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          {%- unless product.has_only_default_variant -%}
            <div class="tm-buybox__opts">
              {%- for variant in product.variants -%}
                <button type="button" class="{% if forloop.first %}is-active{% endif %}"
                        data-tm-variant
                        data-variant-id="{{ variant.id }}"
                        data-variant-price="{{ variant.price | money }}">
                  {{ variant.title }} — {{ variant.price | money }}
                </button>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          {%- if section.settings.show_subscribe_toggle -%}
            <div class="tm-buybox__opts tm-buybox__opts--purchase">
              <button type="button" class="tm-pill tm-pill--onetime is-active">One-time</button>
              <button type="button" class="tm-pill tm-pill--subscribe">Subscribe &amp; Save 15%</button>
            </div>
          {%- endif -%}

          <p class="tm-buybox__price" data-tm-price>{{ product.selected_or_first_available_variant.price | money }}</p>
          {%- if product.available -%}
            <button type="submit" name="add" class="tm-buybox__cta">Add to cart</button>
          {%- else -%}
            <button type="button" class="tm-buybox__cta tm-buybox__cta--soldout" disabled aria-disabled="true">Sold out</button>
          {%- endif -%}
        {% endform %}

        {%- unless product.available -%}
          <div class="tm-notify" data-tm-notify>
            <p class="tm-notify__heading">Notify me when it's back</p>
            {%- form 'customer', id: 'tm-notify-form', class: 'tm-notify__form' -%}
              <input type="hidden" name="contact[tags]" value="back-in-stock,bis-{{ product.handle }}">
              <div class="tm-notify__row">
                <input type="email"
                       name="contact[email]"
                       required
                       placeholder="you@email.com"
                       class="tm-notify__input"
                       aria-label="Email address for restock notification"
                       {% if form.errors %}aria-invalid="true"{% endif %}>
                <button type="submit" class="tm-notify__cta">Notify me</button>
              </div>
              {%- if form.posted_successfully? -%}
                <p class="tm-notify__msg tm-notify__msg--ok" role="status">✓ Thanks — we'll email you the moment it's back.</p>
                <script>
                  (function(){
                    var h = (window.location.hash || '');
                    if (h !== '#tm-notify-form') return;
                    try {
                      sessionStorage.setItem('tm_signup_success', String(Date.now()));
                      sessionStorage.setItem('tm_signup_kind', 'bis');
                    } catch(e){}
                  })();
                </script>
              {%- elsif form.errors -%}
                <p class="tm-notify__msg tm-notify__msg--err" role="alert">
                  {%- if form.errors contains 'email' -%}Please enter a valid email address.{%- else -%}Couldn't submit — please try again.{%- endif -%}
                </p>
              {%- endif -%}
            {%- endform -%}
            <p class="tm-notify__legal">No spam. One email when it's back in stock.</p>
          </div>
        {%- endunless -%}

        {%- if section.blocks.size > 0 -%}
          <div class="tm-buybox__badges">
            {%- for block in section.blocks -%}
              {%- if block.type == 'badge' -%}
                <div class="tm-bb" {{ block.shopify_attributes }}>
                  <div class="tm-bb__icon">{{ block.settings.icon }}</div>
                  <span>{{ block.settings.label }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </section>
  </div>
</div>

{% schema %}
{
  "name": "TMolecule product",
  "tag": "section",
  "class": "tm-main-product",
  "blocks": [
    { "type": "@app" },
    { "type": "title", "name": "Title", "limit": 1 },
    { "type": "price", "name": "Price", "limit": 1 },
    { "type": "variant_picker", "name": "Variant picker", "limit": 1 },
    { "type": "buy_buttons", "name": "Buy buttons", "limit": 1 },
    { "type": "badge", "name": "Trust badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji", "default": "✨" },
        { "type": "text", "id": "label", "label": "Label", "default": "Just<br>Launched" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "label", "label": "Top label", "default": "🔥 BESTSELLER" },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline", "default": "A revitalizing daily ritual from a family who has been curating tea blends since 1935." },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating row", "default": true },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.8 · 216 reviews" },
    { "type": "textarea", "id": "bullets", "label": "Bullets (separate with |)",
      "default": "💪 Collagen peptides in every cup — skin, joints, recovery|🌶️ Warming spice blend: ginger, cinnamon, cardamom|🥥 Keto & paleo friendly — zero sugar, zero fillers|👨‍👩‍👧 Family tea heritage since 1935|☕ Milled powder — brews smoother, no bitter edge|🇺🇸 Made in USA" },
    { "type": "checkbox", "id": "show_subscribe_toggle", "label": "Show subscribe toggle", "default": true }
  ]
}
{% endschema %}
