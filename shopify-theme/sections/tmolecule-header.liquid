<style>
  .tm-header { display:flex; align-items:center; justify-content:center; padding:{{ section.settings.padding }}px 40px; border-bottom:1px solid #e3dbc9; background:rgba(250,247,240,.92); backdrop-filter:saturate(1.4) blur(10px); -webkit-backdrop-filter:saturate(1.4) blur(10px); position:sticky; top:0; z-index:40; transition:padding .25s ease, box-shadow .25s ease; }
  .tm-header.is-scrolled { padding:10px 40px; box-shadow:0 2px 12px rgba(74,55,24,.08); }
  .tm-header__logo { display:inline-flex; align-items:center; text-decoration:none; }
  .tm-header__logo img { height:{{ section.settings.logo_height }}px; width:auto; display:block; transition:height .25s ease, opacity .2s ease; }
  .tm-header.is-scrolled .tm-header__logo img { height:{{ section.settings.logo_height | minus: 8 }}px; }
  .tm-header__logo:hover img { opacity:.85; }
  @media (max-width:720px) { .tm-header { padding:14px 16px; } .tm-header__logo img { height:38px; } }
  @media (max-width:480px) { .tm-header { padding:12px 14px; } .tm-header__logo img { height:34px; } }
</style>

<header class="tm-header" id="tm-header">
  <a class="tm-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
    {%- if section.settings.logo != blank -%}
      <img src="{{ section.settings.logo | image_url: width: 1200 }}" alt="{{ shop.name | escape }}" width="{{ section.settings.logo.width }}" height="{{ section.settings.logo.height }}">
    {%- else -%}
      <img src="https://tmolecule.com/cdn/shop/files/logo.png?v=1654437257&width=1200" alt="{{ shop.name | escape }}">
    {%- endif -%}
  </a>
</header>

<script>
(function(){
  var h = document.getElementById('tm-header');
  if (!h) return;
  var onScroll = function(){ h.classList.toggle('is-scrolled', window.scrollY > 20); };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>

{% schema %}
{
  "name": "TMolecule header",
  "tag": "header",
  "class": "tm-header-section",
  "settings": [
    { "type":"image_picker", "id":"logo", "label":"Custom logo (optional, falls back to default)" },
    { "type":"range", "id":"logo_height", "label":"Logo height (px)", "default":44, "min":24, "max":80, "step":2, "unit":"px" },
    { "type":"range", "id":"padding", "label":"Vertical padding", "default":16, "min":8, "max":40, "step":2, "unit":"px" }
  ],
  "presets": [{"name":"TMolecule header"}]
}
{% endschema %}
