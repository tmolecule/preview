{% comment %}
  TMolecule About page — editorial story with heritage hero, values, timeline, signature.
{% endcomment %}

<div class="tm-page">
  {%- for block in section.blocks -%}
    {%- case block.type -%}

    {%- when 'hero' -%}
      <div class="tm-band tm-band--cream" {{ block.shopify_attributes }}>
        <div class="tm-about-hero">
          <div class="tm-about-hero__copy">
            {%- if block.settings.eyebrow != blank -%}<p class="tm-eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
            {%- if block.settings.heading != blank -%}<h1 class="tm-h1">{{ block.settings.heading }}</h1>{%- endif -%}
            {%- if block.settings.body != blank -%}<div class="rte">{{ block.settings.body }}</div>{%- endif -%}
          </div>
          {%- if block.settings.image != blank -%}
            <div class="tm-about-hero__media"><img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy"></div>
          {%- endif -%}
        </div>
      </div>

    {%- when 'values' -%}
      <div class="tm-band tm-band--sand" {{ block.shopify_attributes }}>
        <div class="tm-values">
          {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
          <div class="tm-values__grid">
            {%- for i in (1..4) -%}
              {%- assign t = 'title_' | append: i -%}
              {%- assign b = 'body_' | append: i -%}
              {%- assign ic = 'icon_' | append: i -%}
              {%- if block.settings[t] != blank -%}
                <div class="tm-values__card">
                  {%- if block.settings[ic] != blank -%}<div class="tm-values__icon">{{ block.settings[ic] }}</div>{%- endif -%}
                  <h3>{{ block.settings[t] }}</h3>
                  <p>{{ block.settings[b] }}</p>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

    {%- when 'timeline' -%}
      <div class="tm-band tm-band--honey" {{ block.shopify_attributes }}>
        <div class="tm-timeline">
          {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
          <ol class="tm-timeline__list">
            {%- for i in (1..6) -%}
              {%- assign y = 'year_' | append: i -%}
              {%- assign b = 'body_' | append: i -%}
              {%- if block.settings[y] != blank -%}
                <li><span class="tm-timeline__year">{{ block.settings[y] }}</span><p>{{ block.settings[b] }}</p></li>
              {%- endif -%}
            {%- endfor -%}
          </ol>
        </div>
      </div>

    {%- when 'signature' -%}
      <div class="tm-band tm-band--espresso" {{ block.shopify_attributes }}>
        <div class="tm-signature">
          {%- if block.settings.quote != blank -%}<blockquote>{{ block.settings.quote }}</blockquote>{%- endif -%}
          {%- if block.settings.author != blank -%}<cite>— {{ block.settings.author }}</cite>{%- endif -%}
          {%- if block.settings.cta_label != blank -%}
            <div class="tm-cta-wrap"><a href="{{ block.settings.cta_link | default: '/collections/all' }}" class="tm-inline-cta">{{ block.settings.cta_label }}{%- if block.settings.cta_sub != blank -%}<span class="tm-inline-cta__sub">{{ block.settings.cta_sub }}</span>{%- endif -%}</a></div>
          {%- endif -%}
        </div>
      </div>

    {%- endcase -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "TMolecule about",
  "tag": "section",
  "class": "tm-about-section",
  "enabled_on": { "templates": ["page"] },
  "settings": [],
  "blocks": [
    { "type":"hero", "name":"Hero", "limit":1, "settings":[
      {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Our story"},
      {"type":"text","id":"heading","label":"Heading","default":"Four generations. One leaf."},
      {"type":"richtext","id":"body","label":"Body","default":"<p>In 1935, our family started sourcing tea — tin by tin, estate by estate, refusing anything that didn't meet the nose test. Ninety-one years later, we're still doing it.</p><p>TMolecule is what happens when four generations of tea obsession meet a modern life. We take the rituals worth keeping and re-engineer them for the cup you'll actually drink tomorrow morning.</p>"},
      {"type":"image_picker","id":"image","label":"Image"}
    ]},
    { "type":"values", "name":"Values", "limit":1, "settings":[
      {"type":"text","id":"heading","label":"Heading","default":"What we believe"},
      {"type":"text","id":"icon_1","label":"Icon 1","default":"🍃"}, {"type":"text","id":"title_1","label":"Title 1","default":"Real ingredients"}, {"type":"text","id":"body_1","label":"Body 1","default":"Whole spices, real tea, hydrolyzed peptides. No \"natural flavors\" mystery blend, no fillers."},
      {"type":"text","id":"icon_2","label":"Icon 2","default":"👨‍👩‍👧"}, {"type":"text","id":"title_2","label":"Title 2","default":"Family heritage"}, {"type":"text","id":"body_2","label":"Body 2","default":"Since 1935. The same nose test, now applied to a cup that respects your time."},
      {"type":"text","id":"icon_3","label":"Icon 3","default":"⚡"}, {"type":"text","id":"title_3","label":"Title 3","default":"Honest energy"}, {"type":"text","id":"body_3","label":"Body 3","default":"Real caffeine from real tea leaves, not synthetic lift. Sustained, not jittery."},
      {"type":"text","id":"icon_4","label":"Icon 4","default":"🌱"}, {"type":"text","id":"title_4","label":"Title 4","default":"Keep it clean"}, {"type":"text","id":"body_4","label":"Body 4","default":"Zero sugar, zero starch, zero additives. Keto & paleo friendly by default, not by accident."}
    ]},
    { "type":"timeline", "name":"Heritage timeline", "limit":1, "settings":[
      {"type":"text","id":"heading","label":"Heading","default":"The long arc"},
      {"type":"text","id":"year_1","label":"Year 1","default":"1935"}, {"type":"text","id":"body_1","label":"Body 1","default":"Great-grandfather sources his first tin of Assam black tea."},
      {"type":"text","id":"year_2","label":"Year 2","default":"1962"}, {"type":"text","id":"body_2","label":"Body 2","default":"Second generation expands to Ceylon and Darjeeling estates."},
      {"type":"text","id":"year_3","label":"Year 3","default":"1989"}, {"type":"text","id":"body_3","label":"Body 3","default":"Third generation formalizes the family tasting protocol."},
      {"type":"text","id":"year_4","label":"Year 4","default":"2023"}, {"type":"text","id":"body_4","label":"Body 4","default":"Fourth generation begins experimenting with milled-leaf blends."},
      {"type":"text","id":"year_5","label":"Year 5","default":"2025"}, {"type":"text","id":"body_5","label":"Body 5","default":"Spice Rush formula finalized — tea, collagen, three spices."},
      {"type":"text","id":"year_6","label":"Year 6","default":"2026"}, {"type":"text","id":"body_6","label":"Body 6","default":"TMolecule launches direct-to-consumer."}
    ]},
    { "type":"signature", "name":"Signature quote", "limit":1, "settings":[
      {"type":"textarea","id":"quote","label":"Quote","default":"Good tea shouldn't need a strainer, a timer, and a degree in horology. It should need you."},
      {"type":"text","id":"author","label":"Author","default":"The TMolecule family"},
      {"type":"text","id":"cta_label","label":"CTA label","default":"Shop the collection"},
      {"type":"text","id":"cta_sub","label":"CTA sublabel","default":"Starting at $6.99"},
      {"type":"url","id":"cta_link","label":"CTA link"}
    ]}
  ],
  "presets": [
    { "name":"TMolecule about", "blocks":[{"type":"hero"},{"type":"values"},{"type":"timeline"},{"type":"signature"}] }
  ]
}
{% endschema %}
