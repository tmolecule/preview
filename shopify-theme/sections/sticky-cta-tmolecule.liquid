{{ 'tmolecule-product.css' | asset_url | stylesheet_tag }}

{%- if template contains 'product' and product -%}
  {%- assign product_in_cart = false -%}
  {%- for item in cart.items -%}
    {%- if item.product_id == product.id -%}
      {%- assign product_in_cart = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}

  {%- assign threshold_cents = section.settings.shipping_threshold | times: 100 -%}
  {%- assign remaining_cents = threshold_cents | minus: cart.total_price -%}
  {%- assign product_price_cents = product.selected_or_first_available_variant.price -%}

  {%- if product_in_cart -%}
    {%- if remaining_cents > 0 -%}
      {%- capture ship_line -%}You're <strong>{{ remaining_cents | money }}</strong> away from free shipping within the US{%- endcapture -%}
    {%- else -%}
      {%- capture ship_line -%}<strong>Free shipping within the US unlocked</strong>{%- endcapture -%}
    {%- endif -%}
  {%- else -%}
    {%- if product_price_cents >= threshold_cents -%}
      {%- capture ship_line -%}<strong>This product ships free in the US</strong>{%- endcapture -%}
    {%- else -%}
      {%- capture ship_line -%}Free shipping within the US over {{ threshold_cents | money }}{%- endcapture -%}
    {%- endif -%}
  {%- endif -%}

<div class="tm-page">
  {%- if product_in_cart -%}
    <!-- CART MODE — current product is already in the cart -->
    <div class="tm-sticky-cta tm-sticky-cta--cart" data-tm-sticky>
      <div class="tm-sticky-cta__cart">
        <div class="tm-sticky-cta__thumbs" aria-hidden="true">
          {%- assign max_thumbs = 4 -%}
          {%- assign shown = 0 -%}
          {%- for item in cart.items -%}
            {%- if shown < max_thumbs and item.image -%}
              <span class="tm-sticky-cta__thumb-wrap">
                <img class="tm-sticky-cta__thumb tm-sticky-cta__thumb--stacked"
                     src="{{ item.image | image_url: width: 120 }}"
                     alt=""
                     loading="lazy">
              </span>
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if cart.item_count > max_thumbs -%}
            {%- assign extra = cart.item_count | minus: max_thumbs -%}
            <span class="tm-sticky-cta__thumb-more">+{{ extra }}</span>
          {%- endif -%}
        </div>
        <div class="tm-sticky-cta__info">
          <p class="tm-sticky-cta__name">{{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %} in your cart</p>
          <p class="tm-sticky-cta__price" data-tm-sticky-price>{{ cart.total_price | money }}</p>
          <p class="tm-sticky-cta__ship">{{ ship_line }}</p>
        </div>
      </div>
      <a href="{{ routes.cart_url }}" class="tm-sticky-cta__btn">{{ section.settings.checkout_label | default: 'Checkout' }}</a>
    </div>
  {%- else -%}
    <!-- PRODUCT MODE — current product not in cart -->
    <div class="tm-sticky-cta" data-tm-sticky>
      <div class="tm-sticky-cta__thumb-stack">
        <div class="tm-sticky-cta__thumb-box">
          {%- if product.featured_media -%}
            <img class="tm-sticky-cta__thumb" src="{{ product.featured_media | image_url: width: 120 }}" alt="">
          {%- endif -%}
          {%- if cart.item_count > 0 -%}
            <span class="tm-sticky-cta__cart-badge" aria-label="{{ cart.item_count }} items already in cart">
              {{ cart.item_count }}
            </span>
          {%- endif -%}
        </div>
        {%- if cart.item_count > 0 -%}
          <span class="tm-sticky-cta__in-cart-label">In cart</span>
        {%- endif -%}
      </div>
      <div class="tm-sticky-cta__info">
        <p class="tm-sticky-cta__name">{{ product.title }}</p>
        <p class="tm-sticky-cta__price" data-tm-sticky-price>{{ product.selected_or_first_available_variant.price | money }}</p>
        <p class="tm-sticky-cta__ship">{{ ship_line }}</p>
      </div>
      <button type="button" class="tm-sticky-cta__btn" data-tm-sticky-atc>{{ section.settings.cta_label | default: 'Add to cart' }}</button>
    </div>
  {%- endif -%}
</div>
{%- endif -%}

{% schema %}
{
  "name": "TMolecule sticky CTA",
  "tag": "section",
  "class": "tm-sticky-cta-section",

  "settings": [
    { "type": "text", "id": "cta_label", "label": "Button label (product not in cart)", "default": "Add to cart" },
    { "type": "text", "id": "checkout_label", "label": "Button label (product in cart)", "default": "Checkout" },
    { "type": "number", "id": "shipping_threshold", "label": "Free shipping threshold ($)", "default": 35, "info":"Whole dollars. E.g. 35 = free US shipping over $35." }
  ],
  "presets": [ { "name": "TMolecule sticky CTA" } ]
}
{% endschema %}
