<style>
  .tm-popup {
    --ink:#1a1816; --cream:#faf7f0; --sand:#f5e9d0; --warm:#ede0c4; --terra:#c87040; --terra-dark:#a85830; --espresso:#1a1610;
    position:fixed; inset:0; z-index:9998;
    background:rgba(26,22,16,.55); backdrop-filter:blur(4px); -webkit-backdrop-filter:blur(4px);
    display:flex; align-items:center; justify-content:center; padding:24px;
    opacity:0; pointer-events:none;
    transition:opacity .35s ease;
    font-family:'Fraunces', Georgia, serif; color:var(--ink);
  }
  .tm-popup.is-open { opacity:1; pointer-events:auto; }
  .tm-popup__panel {
    position:relative;
    max-width:480px; width:100%;
    background:linear-gradient(180deg, #fefaf0 0%, #f5e9d0 100%);
    border-radius:16px; padding:44px 36px 36px;
    box-shadow:0 40px 80px -16px rgba(26,22,16,.5), 0 16px 40px -8px rgba(74,55,24,.35), 0 4px 12px rgba(26,22,16,.18);
    transform:scale(.94) translateY(10px);
    transition:transform .4s cubic-bezier(.34,1.3,.64,1);
  }
  .tm-popup.is-open .tm-popup__panel { transform:scale(1) translateY(0); }
  .tm-popup__close { position:absolute; top:12px; right:14px; width:32px; height:32px; border:0; background:transparent; cursor:pointer; font-size:22px; color:var(--ink); opacity:.5; transition:opacity .15s ease; line-height:1; padding:0; }
  .tm-popup__close:hover { opacity:1; }

  .tm-popup__eyebrow { text-transform:uppercase; letter-spacing:.22em; font-size:10px; color:var(--terra-dark); margin:0 0 10px; font-family:'Inter'; font-weight:800; text-align:center; }
  .tm-popup__heading { font-size:clamp(26px,3.4vw,34px); line-height:1.1; font-weight:800; letter-spacing:-.02em; margin:0 0 8px; text-align:center; }
  .tm-popup__body { font-family:'Inter'; font-size:14.5px; line-height:1.5; opacity:.85; text-align:center; margin:0 0 24px; }

  .tm-popup__form { display:grid; gap:12px; }
  .tm-popup-section .tm-honeypot, .tm-popup .tm-honeypot { position:absolute !important; left:-9999px !important; top:-9999px !important; width:1px !important; height:1px !important; opacity:0 !important; pointer-events:none !important; border:0 !important; }
  .tm-popup__form label { display:grid; gap:6px; font-family:'Inter'; font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--terra-dark); font-weight:700; }
  .tm-popup__form input { padding:14px 16px; border:1.5px solid #e3dbc9; border-radius:10px; font-family:'Inter'; font-size:15px; background:#fff; color:var(--ink); transition:border-color .15s ease, box-shadow .15s ease; }
  .tm-popup__form input:focus { outline:0; border-color:var(--terra); box-shadow:0 0 0 3px rgba(200,112,64,.15); }

  .tm-popup__submit {
    margin-top:10px; padding:18px 28px;
    background:var(--terra); color:#fff; border:0;
    font-family:'Inter'; font-size:13px; font-weight:800; letter-spacing:.16em; text-transform:uppercase;
    cursor:pointer;
    filter:drop-shadow(0 8px 20px rgba(200,112,64,.4));
    transition:filter .2s ease, transform .2s ease, background .2s ease;
    -webkit-mask-image:
      radial-gradient(circle 3px at 9px 0,     transparent 3px, #000 3.5px),
      radial-gradient(circle 3px at 9px 100%,  transparent 3px, #000 3.5px),
      radial-gradient(circle 3px at 0 9px,     transparent 3px, #000 3.5px),
      radial-gradient(circle 3px at 100% 9px,  transparent 3px, #000 3.5px);
    -webkit-mask-size:18px 100%, 18px 100%, 100% 18px, 100% 18px;
    -webkit-mask-repeat:repeat-x, repeat-x, repeat-y, repeat-y;
    -webkit-mask-position:top, bottom, left, right;
    -webkit-mask-composite:source-in;
    mask-image:
      radial-gradient(circle 3px at 9px 0,     transparent 3px, #000 3.5px),
      radial-gradient(circle 3px at 9px 100%,  transparent 3px, #000 3.5px),
      radial-gradient(circle 3px at 0 9px,     transparent 3px, #000 3.5px),
      radial-gradient(circle 3px at 100% 9px,  transparent 3px, #000 3.5px);
    mask-size:18px 100%, 18px 100%, 100% 18px, 100% 18px;
    mask-repeat:repeat-x, repeat-x, repeat-y, repeat-y;
    mask-position:top, bottom, left, right;
    mask-composite:intersect;
  }
  .tm-popup__submit:hover { background:var(--terra-dark); transform:translateY(-1px); filter:drop-shadow(0 12px 26px rgba(200,112,64,.55)); }

  .tm-popup__fineprint { font-family:'Inter'; font-size:11px; opacity:.6; margin:16px 0 0; text-align:center; line-height:1.5; }
  .tm-popup__no-thanks { display:block; margin-top:14px; font-family:'Inter'; font-size:11px; letter-spacing:.08em; text-transform:uppercase; background:transparent; border:0; color:var(--ink); opacity:.55; cursor:pointer; text-align:center; width:100%; padding:4px; }
  .tm-popup__no-thanks:hover { opacity:.9; text-decoration:underline; }

  .tm-popup__errors { text-align:left; padding:14px; background:#fce8e8; border:1px solid #f0a0a0; border-radius:10px; font-family:'Inter'; font-size:13px; color:#8a1515; margin-bottom:12px; }
  .tm-popup__errors ul { margin:6px 0 0 18px; padding:0; }

  /* Success state */
  .tm-popup__progress { position:absolute; top:0; left:0; right:0; height:4px; background:rgba(200,112,64,.15); border-radius:16px 16px 0 0; overflow:hidden; opacity:0; pointer-events:none; }
  .tm-popup__progress > span { display:block; height:100%; background:linear-gradient(90deg,var(--terra),var(--terra-dark)); transform-origin:left; transform:scaleX(1); }
  .tm-popup.is-success .tm-popup__progress { opacity:1; }
  .tm-popup.is-success.is-open .tm-popup__progress > span { animation: tm-popup-shrink var(--tm-popup-autoclose,5s) linear forwards; }
  .tm-popup.is-paused .tm-popup__progress > span { animation-play-state: paused; }
  @keyframes tm-popup-shrink { from { transform:scaleX(1); } to { transform:scaleX(0); } }

  .tm-popup__confirm { display:none; text-align:center; padding-top:6px; }
  .tm-popup.is-success .tm-popup__confirm { display:block; }
  .tm-popup.is-success .tm-popup__form { display:none; }
  .tm-popup__confirm--bis { display:none !important; }
  .tm-popup.is-success.is-bis .tm-popup__confirm:not(.tm-popup__confirm--bis) { display:none; }
  .tm-popup.is-success.is-bis .tm-popup__confirm--bis { display:block !important; }
  .tm-popup__check { display:flex; justify-content:center; margin:0 0 18px; }
  .tm-popup__check svg { display:block; filter:drop-shadow(0 8px 20px rgba(200,112,64,.35)); }
  .tm-popup.is-success .tm-popup__check svg { animation: tm-popup-pop .55s cubic-bezier(.34,1.5,.64,1) both; }
  @keyframes tm-popup-pop { 0% { transform:scale(.4); opacity:0; } 60% { transform:scale(1.08); opacity:1; } 100% { transform:scale(1); } }
  .tm-popup__confirm .tm-popup__heading { margin-bottom:10px; }
  .tm-popup__confirm .tm-popup__body { margin-bottom:8px; opacity:.85; }
  .tm-popup__confirm-hint { font-family:'Inter'; font-size:11px; opacity:.55; margin:18px 0 0; text-align:center; letter-spacing:.06em; }

  @media (max-width:520px) {
    .tm-popup__panel { padding:36px 24px 28px; }
  }
</style>

{%- assign tm_autoclose = section.settings.success_autoclose_seconds | default: 5 -%}
<div class="tm-popup"
     data-tm-popup
     data-posted="false"
     data-time-delay="{% if section.settings.enable_time_delay %}true{% else %}false{% endif %}"
     data-exit-intent="{% if section.settings.enable_exit_intent %}true{% else %}false{% endif %}"
     data-delay="{{ section.settings.delay_seconds | default: 8 }}"
     data-cooldown-days="{{ section.settings.cooldown_days | default: 7 }}"
     style="--tm-popup-autoclose:{{ tm_autoclose }}s;"
     role="dialog" aria-modal="true" aria-labelledby="tm-popup-heading" aria-hidden="true" inert>
  <div class="tm-popup__panel">
    <div class="tm-popup__progress" aria-hidden="true"><span></span></div>
    <button type="button" class="tm-popup__close" data-tm-popup-close aria-label="Close">×</button>

    <div class="tm-popup__confirm">
      <div class="tm-popup__check" aria-hidden="true">
        <svg viewBox="0 0 60 60" width="64" height="64" xmlns="http://www.w3.org/2000/svg">
          <circle cx="30" cy="30" r="27" fill="#c87040"/>
          <path d="M18 31 L26 39 L43 22" stroke="#faf3e0" stroke-width="4.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <p class="tm-popup__eyebrow">{{ section.settings.success_eyebrow | default: 'Welcome to the ritual' }}</p>
      <h2 class="tm-popup__heading">{{ section.settings.success_heading | default: "You're in." }}</h2>
      <p class="tm-popup__body">{{ section.settings.success_text | default: "Check your inbox in the next few minutes — your code is on its way. Watch for an email + SMS from TMolecule." }}</p>
      <p class="tm-popup__confirm-hint">This window closes automatically — hover to keep it open.</p>
    </div>

    <div class="tm-popup__confirm tm-popup__confirm--bis">
      <div class="tm-popup__check" aria-hidden="true">
        <svg viewBox="0 0 60 60" width="64" height="64" xmlns="http://www.w3.org/2000/svg">
          <circle cx="30" cy="30" r="27" fill="#c87040"/>
          <path d="M18 31 L26 39 L43 22" stroke="#faf3e0" stroke-width="4.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <p class="tm-popup__eyebrow">Saved</p>
      <h2 class="tm-popup__heading">You'll be the first to know</h2>
      <p class="tm-popup__body">We'll email you the moment this is back in stock. No spam — one email, then nothing.</p>
      <p class="tm-popup__confirm-hint">This window closes automatically — hover to keep it open.</p>
    </div>

    <form id="tm-popup-form"
          class="tm-popup__form"
          action="https://e7dedec4.sibforms.com/serve/MUIFAKhcKEYJNpH6yFLTTyyw6dsaJyRzRDJOtJMZUozCx96gJSvDx05z9KdeIZ2VNVd7ljRA0_TQapbeJLXnLOhf6UdMN0OKo4l9HMQA_jINgVU-hxwQb5WAc2CYH-UTHXWDfg0tOHfNyQGWbpRiotdwR4iSdPMm8drYD6Adt7EsuUj5mJpvY5dAndmrqGPieFmEW949eoKfmtysGw=="
          method="POST"
          target="tm-popup-brevo-target">
      <p class="tm-popup__eyebrow">{{ section.settings.eyebrow | default: 'Join the ritual' }}</p>
      <h2 id="tm-popup-heading" class="tm-popup__heading">{{ section.settings.heading | default: "Get 10% off your first order" }}</h2>
      <p class="tm-popup__body">{{ section.settings.body | default: "Join our email & SMS list for early access, seasonal blends, and a discount on your first order." }}</p>

      <label>Email
        <input type="email" name="EMAIL" autocomplete="email" required placeholder="you@example.com">
      </label>
      <label>Mobile number
        <input type="tel" name="SMS" autocomplete="tel" required placeholder="(555) 123-4567">
      </label>

      <input type="hidden" name="SMS__COUNTRY_CODE" value="+1">
      <input type="hidden" name="locale" value="en">
      <input type="hidden" name="html_type" value="simple">
      <input type="text" name="email_address_check" value="" class="tm-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true">

      <button type="submit" class="tm-popup__submit">{{ section.settings.button_label | default: "Send me the code" }}</button>
      <p class="tm-popup__fineprint">{{ section.settings.fineprint | default: "By submitting, you agree to receive email and SMS marketing from TMolecule. Message & data rates may apply. Unsubscribe any time." }}</p>
      <button type="button" class="tm-popup__no-thanks" data-tm-popup-close>No thanks</button>
      <p class="tm-popup__errors" data-tm-popup-error hidden></p>
    </form>
    <iframe name="tm-popup-brevo-target" id="tm-popup-brevo-target" title="Popup signup target" tabindex="-1" aria-hidden="true" class="tm-honeypot"></iframe>
    <script>
      (function(){
        var f = document.getElementById('tm-popup-form');
        var iframe = document.getElementById('tm-popup-brevo-target');
        if (!f || !iframe) return;
        var btn = f.querySelector('button[type="submit"]');
        var origText = btn ? btn.textContent : '';

        var onResponse = function(){
          iframe.removeEventListener('load', onResponse);
          try { sessionStorage.setItem('tm_signup_success', String(Date.now())); } catch(e){}
          window.location.reload();
        };

        f.addEventListener('submit', function(e){
          // Honeypot — bot detected, silently no-op
          var hp = f.elements['email_address_check'];
          if (hp && hp.value) { e.preventDefault(); return; }

          // Brevo SMS validation: digits-only, country code embedded in number.
          // Strip non-digits and prepend "1" if user didn't (US default).
          var smsField = f.elements['SMS'];
          if (smsField) {
            var digits = (smsField.value || '').replace(/\D/g, '');
            if (digits.length === 10) digits = '1' + digits;
            smsField.value = digits;
          }

          if (btn) { btn.disabled = true; btn.textContent = 'Joining…'; }
          iframe.addEventListener('load', onResponse);
          // Fallback if iframe load doesn't fire within 6s
          setTimeout(function(){
            iframe.removeEventListener('load', onResponse);
            try { sessionStorage.setItem('tm_signup_success', String(Date.now())); } catch(e){}
            window.location.reload();
          }, 6000);
        });
      })();
    </script>
  </div>
</div>

<script>
(function(){
  var popup = document.querySelector('[data-tm-popup]');
  if (!popup) return;
  var delay = parseInt(popup.dataset.delay || '8', 10) * 1000;
  var cooldown = parseInt(popup.dataset.cooldownDays || '7', 10) * 86400000;
  var exitIntent = (popup.dataset.exitIntent || 'false') === 'true';
  var timeDelay = (popup.dataset.timeDelay || 'false') === 'true';
  var posted = (popup.dataset.posted || 'false') === 'true';
  var key = 'tm_popup_dismissed_at';
  var signupKey = 'tm_signup_success';
  var fired = false;
  var closed = false;

  // Dev override via URL query — never trip the cooldown so testing stays fast.
  // ?tm_popup=force   → open immediately, ignore cooldown
  // ?tm_popup=success → open immediately in success state (preview the confirm panel)
  var forceMode = '';
  try {
    forceMode = (new URL(window.location.href)).searchParams.get('tm_popup') || '';
  } catch(e) {}
  if (forceMode === 'success') {
    posted = true;
    popup.classList.add('is-success');
    popup.dataset.posted = 'true';
  }

  // If a sibling signup form (e.g. footer newsletter, product notify-me) just posted
  // successfully, it leaves a timestamp + kind in sessionStorage. Honor it if recent
  // (<15s). Kind 'bis' means a back-in-stock notify-me form was the submitter and the
  // popup should show its BIS-specific confirm copy.
  try {
    var sig = sessionStorage.getItem(signupKey);
    var kind = sessionStorage.getItem('tm_signup_kind') || 'newsletter';
    if (sig) {
      sessionStorage.removeItem(signupKey);
      sessionStorage.removeItem('tm_signup_kind');
      var t = parseInt(sig, 10);
      if (!isNaN(t) && (Date.now() - t) < 15000) {
        posted = true;
        popup.classList.add('is-success');
        if (kind === 'bis') popup.classList.add('is-bis');
        popup.dataset.posted = 'true';
      }
    }
  } catch(e) {}

  function shouldShow(){
    if (forceMode) return true;
    try {
      var dismissed = parseInt(localStorage.getItem(key) || '0', 10);
      return !dismissed || (Date.now() - dismissed) > cooldown;
    } catch(e) { return true; }
  }
  function open(){
    if (fired) return;
    fired = true;
    popup.classList.add('is-open');
    popup.setAttribute('aria-hidden', 'false');
    popup.removeAttribute('inert');
    document.body.style.overflow = 'hidden';
    if (!posted) {
      var input = popup.querySelector('input[type="email"], input[type="tel"]');
      if (input) setTimeout(function(){ input.focus(); }, 100);
    }
  }
  function close(){
    if (closed) return;
    closed = true;
    popup.classList.remove('is-open');
    popup.setAttribute('aria-hidden', 'true');
    popup.setAttribute('inert', '');
    document.body.style.overflow = '';
    if (!posted && !forceMode) {
      try { localStorage.setItem(key, Date.now().toString()); } catch(e) {}
    }
  }
  function trigger(){ if (shouldShow()) open(); }

  if (posted) {
    // Success state — open immediately and auto-close when the progress bar finishes
    open();
    var bar = popup.querySelector('.tm-popup__progress > span');
    if (bar) {
      bar.addEventListener('animationend', close, { once: true });
    } else {
      setTimeout(close, 5000);
    }
    // Pause auto-close while hovering or focused inside
    var pause = function(){ popup.classList.add('is-paused'); };
    var resume = function(){ popup.classList.remove('is-paused'); };
    popup.addEventListener('mouseenter', pause);
    popup.addEventListener('mouseleave', resume);
    popup.addEventListener('focusin', pause);
    popup.addEventListener('focusout', resume);
  } else if (forceMode === 'force') {
    open();
  } else if (shouldShow()) {
    if (timeDelay) {
      setTimeout(trigger, delay);
    }
    if (exitIntent && window.matchMedia('(min-width: 901px) and (pointer: fine)').matches) {
      var onExit = function(e){
        if (e.clientY <= 0 && !e.relatedTarget) {
          document.removeEventListener('mouseout', onExit);
          trigger();
        }
      };
      document.addEventListener('mouseout', onExit);
    }
  }

  popup.querySelectorAll('[data-tm-popup-close]').forEach(function(b){
    b.addEventListener('click', close);
  });
  popup.addEventListener('click', function(e){
    if (e.target === popup) close();
  });
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape') close();
  });
})();
</script>

{% schema %}
{
  "name": "TMolecule popup",
  "tag": "section",
  "class": "tm-popup-section",
  "settings": [
    { "type":"text", "id":"eyebrow", "label":"Eyebrow", "default":"Join the ritual" },
    { "type":"text", "id":"heading", "label":"Heading", "default":"Get 10% off your first order" },
    { "type":"textarea", "id":"body", "label":"Body", "default":"Join our email & SMS list for early access, seasonal blends, and a discount on your first order." },
    { "type":"text", "id":"button_label", "label":"Button label", "default":"Send me the code" },
    { "type":"textarea", "id":"fineprint", "label":"Fine print / consent", "default":"By submitting, you agree to receive email and SMS marketing from TMolecule. Message & data rates may apply. Unsubscribe any time." },
    { "type":"header", "content":"Success state" },
    { "type":"text", "id":"success_eyebrow", "label":"Success eyebrow", "default":"Welcome to the ritual" },
    { "type":"text", "id":"success_heading", "label":"Success heading", "default":"You're in." },
    { "type":"textarea", "id":"success_text", "label":"Success body", "default":"Check your inbox in the next few minutes — your code is on its way. Watch for an email + SMS from TMolecule." },
    { "type":"range", "id":"success_autoclose_seconds", "label":"Auto-close after (s)", "min":3, "max":15, "step":1, "default":5, "unit":"s", "info":"How long the success window stays open before auto-closing. Visitors can keep it open by hovering, click the X, press Esc, or click the dim background." },
    { "type":"header", "content":"Triggers" },
    { "type":"paragraph", "content":"Choose how the popup opens. Exit-intent fires only when a desktop visitor moves the cursor to leave, so visitors can read and copy text freely first. Time-delay blocks the page until dismissed — leave it OFF unless you want that." },
    { "type":"checkbox", "id":"enable_exit_intent", "label":"Show on exit intent (desktop only)", "default":true, "info":"Opens when a desktop visitor moves the cursor toward the top of the window to leave." },
    { "type":"checkbox", "id":"enable_time_delay", "label":"Show after time delay", "default":true, "info":"Opens automatically after the delay below — the classic 'show after a few seconds' behavior." },
    { "type":"header", "content":"Timing" },
    { "type":"range", "id":"delay_seconds", "label":"Time delay (s)", "min":0, "max":60, "step":1, "default":8, "unit":"s" },
    { "type":"range", "id":"cooldown_days", "label":"Re-show cooldown after dismiss (days)", "min":1, "max":60, "step":1, "default":7, "unit":"d" }
  ],
  "presets": [{ "name":"TMolecule popup" }]
}
{% endschema %}
