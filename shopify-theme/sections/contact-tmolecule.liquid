<style>
  .tm-contact { --ink:#1a1816; --cream:#f8f4eb; --sand:#e9dfcf; --warm:#d7ceb2; --terra:#c87040; --terra-dark:#a85830; --espresso:#1a1610; color:var(--ink); font-family:'Fraunces', Georgia, serif; background:linear-gradient(135deg,#faf6ec 0%,#ede0c4 60%,#d7ceb2 100%); padding:80px 24px; min-height:70vh; }
  .tm-contact__grid { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1.1fr; gap:64px; }
  .tm-contact__intro h1 { font-size:clamp(36px,5vw,64px); line-height:1.0; letter-spacing:-.03em; font-weight:700; margin:0 0 20px; }
  .tm-contact__intro .tm-eyebrow { text-transform:uppercase; letter-spacing:.18em; font-size:11px; color:var(--terra); margin:0 0 12px; font-family:'Inter'; font-weight:700; }
  .tm-contact__intro .tm-body { font-family:'Inter'; font-size:17px; line-height:1.65; opacity:.85; max-width:55ch; margin:0 0 32px; }
  .tm-contact__details { list-style:none; padding:0; margin:40px 0 0; display:grid; gap:16px; }
  .tm-contact__details li { display:grid; grid-template-columns:110px 1fr; gap:16px; padding:16px 0; border-top:1px solid rgba(26,22,16,.12); font-family:'Inter'; font-size:15px; align-items:baseline; }
  .tm-contact__details strong { font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--terra); font-weight:700; }
  .tm-contact__details a { color:var(--ink); text-decoration:none; border-bottom:1px solid rgba(200,112,64,.3); transition:border-color .15s ease; }
  .tm-contact__details a:hover { border-color:var(--terra); }
  .tm-contact__social { margin-top:40px; padding-top:32px; border-top:1px solid rgba(26,22,16,.12); }
  .tm-contact__social-label { font-family:'Inter'; font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--terra); font-weight:700; margin:0 0 16px; }
  .tm-contact__social-icons { display:flex; gap:12px; }
  .tm-contact__social-icons a { width:44px; height:44px; border-radius:50%; background:rgba(200,112,64,.12); color:var(--terra-dark); display:flex; align-items:center; justify-content:center; transition:background .2s ease, transform .2s ease, color .2s ease; }
  .tm-contact__social-icons a:hover { background:var(--terra); color:#fff; transform:translateY(-2px); }
  .tm-contact__form-wrap { background:linear-gradient(160deg,#fdf6e6 0%,#f5e9d0 100%); border-radius:16px; padding:40px; box-shadow:0 40px 80px -20px rgba(74,55,24,.45), 0 16px 40px -8px rgba(74,55,24,.3), 0 4px 12px rgba(26,22,16,.12); border:1px solid rgba(200,112,64,.15); }
  .tm-contact__form { display:grid; gap:18px; font-family:'Inter'; }
  .tm-contact__form label { display:grid; gap:8px; font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--terra); font-weight:700; }
  .tm-contact__form input, .tm-contact__form textarea { padding:14px 16px; border:1px solid #e3dbc9; border-radius:10px; font-family:'Inter'; font-size:15px; background:#faf7f0; color:var(--ink); transition:border-color .15s ease, box-shadow .15s ease; }
  .tm-contact__form input:focus, .tm-contact__form textarea:focus { outline:0; border-color:var(--terra); box-shadow:0 0 0 3px rgba(200,112,64,.15); }
  .tm-contact__form textarea { resize:vertical; min-height:140px; }
  .tm-contact__submit { padding:18px 44px; background:var(--terra); color:#fff; border:0; border-radius:14px; font-family:'Inter'; font-size:15px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; cursor:pointer; box-shadow:0 6px 20px rgba(200,112,64,.35); transition:all .2s ease; margin-top:8px; }
  .tm-contact__submit:hover { transform:translateY(-2px); box-shadow:0 10px 30px rgba(200,112,64,.45); background:var(--terra-dark); }
  .tm-contact__success { background:linear-gradient(135deg,#e8f5e0,#d0e8c0); border:1px solid #a0c880; padding:16px; border-radius:10px; font-family:'Inter'; font-size:14px; color:#3a5a28; margin-bottom:8px; }
  .tm-contact__errors { background:linear-gradient(135deg,#fce8e8,#f5d0d0); border:1px solid #f0a0a0; padding:16px; border-radius:10px; font-family:'Inter'; font-size:14px; color:#8a1515; margin-bottom:8px; }
  .tm-contact__errors ul { margin:8px 0 0 20px; }
  @media (max-width:860px) { .tm-contact__grid { grid-template-columns:1fr; gap:40px; } .tm-contact__form-wrap { padding:28px 20px; } .tm-contact { padding:48px 16px; } }
</style>

<div class="tm-contact">
  <div class="tm-contact__grid">
    <div class="tm-contact__intro">
      <p class="tm-eyebrow">{{ section.settings.eyebrow | default: 'Get in touch' }}</p>
      <h1>{{ section.settings.heading | default: "We'd love to hear from you" }}</h1>
      <p class="tm-body">{{ section.settings.body | default: "Questions about your order, wholesale inquiries, or a collaboration idea? Drop us a note and we'll reply within one business day." }}</p>

      <ul class="tm-contact__details">
        {%- if section.settings.email != blank -%}
          <li><strong>Email</strong><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></li>
        {%- endif -%}
        {%- if section.settings.phone != blank -%}
          <li><strong>Phone</strong><a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}">{{ section.settings.phone }}</a></li>
        {%- endif -%}
        {%- if section.settings.hours != blank -%}
          <li><strong>Hours</strong><span>{{ section.settings.hours }}</span></li>
        {%- endif -%}
        {%- if section.settings.address != blank -%}
          <li><strong>Mailing</strong><span>{{ section.settings.address }}</span></li>
        {%- endif -%}
      </ul>

      <div class="tm-contact__social">
        <p class="tm-contact__social-label">Follow us</p>
        <div class="tm-contact__social-icons">
          <a href="https://facebook.com/GetTMolecule" aria-label="Facebook" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.3-1.5 1.5-1.5h1.6V3.6c-.3 0-1.2-.1-2.3-.1-2.3 0-3.9 1.4-3.9 4v2.3H7.7V13h2.6v8h3.2z"/></svg></a>
          <a href="https://instagram.com/tmolecule.official" aria-label="Instagram" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
          <a href="https://tiktok.com/@tmolecule" aria-label="TikTok" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M19.3 8.6c-1.6 0-3-.6-4-1.6-.7-.7-1.2-1.7-1.4-2.8h-3v11.3c0 1.3-1.1 2.4-2.4 2.4-1.3 0-2.4-1.1-2.4-2.4s1.1-2.4 2.4-2.4c.3 0 .5 0 .8.1v-3c-.3 0-.5-.1-.8-.1-3 0-5.4 2.4-5.4 5.4s2.4 5.4 5.4 5.4 5.4-2.4 5.4-5.4V10c1.1.7 2.4 1.1 3.8 1.1h.7v-2.5h-.1z"/></svg></a>
          <a href="https://twitter.com/GetTMolecule" aria-label="X" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M17.5 3h3l-6.6 7.5L22 21h-6.2l-4.8-6.3L5.3 21H2.3l7-8L2 3h6.3l4.4 5.8L17.5 3zm-1 16h1.7L7.6 4.8H5.8L16.5 19z"/></svg></a>
        </div>
      </div>
    </div>

    <div class="tm-contact__form-wrap">
      {%- form 'contact', id: 'tm-contact-form', class: 'tm-contact__form' -%}
        {%- if form.posted_successfully? -%}
          <div class="tm-contact__success"><p>Thank you — we'll get back to you within one business day.</p></div>
        {%- endif -%}
        {%- if form.errors -%}
          <div class="tm-contact__errors">
            <p>Please correct the following:</p>
            <ul>
              {%- for error in form.errors -%}
                <li>{{ form.errors.messages[error] }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
        <label>Name<input type="text" name="contact[name]" value="{%- if form.name -%}{{ form.name }}{%- elsif customer -%}{{ customer.name }}{%- endif -%}" required></label>
        <label>Email<input type="email" name="contact[email]" value="{%- if form.email -%}{{ form.email }}{%- elsif customer -%}{{ customer.email }}{%- endif -%}" required></label>
        <label>Phone<input type="tel" name="contact[phone]" value="{{ form.phone }}" required></label>
        <label>Message<textarea name="contact[body]" required>{{ form.body }}</textarea></label>
        <button class="tm-contact__submit" type="submit">Send message</button>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "TMolecule contact",
  "tag": "section",
  "class": "tm-contact-section",
  "settings": [
    { "type":"text", "id":"eyebrow", "label":"Eyebrow", "default":"Get in touch" },
    { "type":"text", "id":"heading", "label":"Heading", "default":"We'd love to hear from you" },
    { "type":"textarea", "id":"body", "label":"Intro body", "default":"Questions about your order, wholesale inquiries, or a collaboration idea? Drop us a note and we'll reply within one business day." },
    { "type":"text", "id":"email", "label":"Email", "default":"support@tmolecule.com" },
    { "type":"text", "id":"phone", "label":"Phone" },
    { "type":"text", "id":"hours", "label":"Hours", "default":"Mon–Fri · 9am–5pm ET" },
    { "type":"text", "id":"address", "label":"Mailing address" }
  ],
  "presets": [{ "name":"TMolecule contact" }]
}
{% endschema %}
