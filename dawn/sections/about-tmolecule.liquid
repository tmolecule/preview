<style>
  .tm-about { --ink:#1a1816; --cream:#f8f4eb; --sand:#e9dfcf; --warm:#d7ceb2; --terra:#c87040; --terra-dark:#a85830; --espresso:#1a1610; color:var(--ink); font-family:'Fraunces', Georgia, serif; }
  .tm-about img { max-width:100%; display:block; }
  .tm-section { padding:100px 24px; overflow:hidden; }
  .tm-section__inner { max-width:1200px; margin:0 auto; }
  .tm-section--cream { background:linear-gradient(135deg,#faf6ec 0%,#ede0c4 60%,#d7ceb2 100%); }
  .tm-section--sand { background:var(--sand); }
  .tm-section--dark { background:var(--espresso); color:#f5ecd8; }
  .tm-section--terra { background:linear-gradient(135deg,#c87040 0%,#a85830 50%,#884020 100%); color:#faf3e0; }
  .tm-h1 { font-size:clamp(42px,6vw,80px); line-height:1.0; letter-spacing:-.03em; font-weight:700; margin:0 0 20px; }
  .tm-h2 { font-size:clamp(32px,4.5vw,56px); line-height:1.05; letter-spacing:-.02em; font-weight:700; margin:0 0 16px; }
  .tm-eyebrow { text-transform:uppercase; letter-spacing:.18em; font-size:11px; color:var(--terra); margin:0 0 12px; font-family:'Inter'; font-weight:700; }
  .tm-body { font-family:'Inter'; font-size:17px; line-height:1.65; opacity:.9; max-width:60ch; }
  .tm-section--dark .tm-eyebrow { color:#d4a060; }
  .tm-section--dark .tm-h2 { color:#f5ecd8; }
  .tm-section--terra .tm-eyebrow { color:#fce8d0; }
  .tm-btn { display:inline-flex; align-items:center; gap:8px; padding:18px 44px; background:var(--terra); color:#fff; border:0; border-radius:14px; font-family:'Inter'; font-size:15px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; text-decoration:none; cursor:pointer; box-shadow:0 6px 20px rgba(200,112,64,.35); transition:all .2s ease; }
  .tm-btn:hover { transform:translateY(-2px); box-shadow:0 10px 30px rgba(200,112,64,.45); background:var(--terra-dark); }
  .tm-btn__sub { display:block; font-size:11px; font-weight:500; opacity:.8; margin-top:2px; letter-spacing:.08em; }
  .tm-section--terra .tm-btn { background:var(--espresso); box-shadow:0 6px 20px rgba(26,22,16,.4); }

  /* HERO */
  .tm-about-hero { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1.05fr; gap:64px; align-items:center; padding:100px 24px; }
  .tm-about-hero__media { position:relative; overflow:hidden; border-radius:16px; box-shadow:0 40px 80px -20px rgba(74,55,24,.45), 0 16px 40px -8px rgba(74,55,24,.3), 0 4px 12px rgba(26,22,16,.12); background:radial-gradient(circle at 30% 20%,#f8ebd0 0%,#e8d6b0 55%,#c8b48a 100%); }
  .tm-about-hero__media img { width:100%; height:auto; display:block; mix-blend-mode:multiply; }

  /* VALUES GRID */
  .tm-about-values { text-align:center; }
  .tm-about-values__grid { display:grid; grid-template-columns:repeat(4,1fr); gap:24px; margin-top:48px; }
  .tm-about-values__card { background:var(--cream); border-radius:16px; padding:40px 24px 32px; text-align:center; box-shadow:0 30px 60px -20px rgba(74,55,24,.3), 0 8px 24px -4px rgba(74,55,24,.2); }
  .tm-about-values__icon { font-size:40px; margin-bottom:16px; }
  .tm-about-values__card h3 { font-size:19px; font-weight:700; margin:0 0 10px; }
  .tm-about-values__card p { font-family:'Inter'; font-size:14px; line-height:1.55; opacity:.8; margin:0; }

  /* TIMELINE */
  .tm-about-timeline { max-width:900px; margin:0 auto; }
  .tm-about-timeline__list { list-style:none; padding:0; margin:40px 0 0; display:grid; gap:16px; }
  .tm-about-timeline__list li { display:grid; grid-template-columns:120px 1fr; gap:32px; padding:24px 0; border-top:1px solid rgba(74,55,24,.15); font-family:'Inter'; align-items:baseline; }
  .tm-about-timeline__year { font-family:'Fraunces', Georgia, serif; font-size:36px; font-weight:700; color:var(--terra); line-height:1; }
  .tm-about-timeline__list p { margin:0; font-size:16px; line-height:1.6; }

  /* QUOTE / SIGNATURE */
  .tm-about-signature { text-align:center; max-width:900px; margin:0 auto; padding:80px 24px; }
  .tm-about-signature blockquote { font-family:'Fraunces', Georgia, serif; font-size:clamp(24px,3.5vw,40px); line-height:1.25; margin:0 0 24px; font-style:italic; color:#f5ecd8; }
  .tm-about-signature cite { font-family:'Inter'; font-size:13px; letter-spacing:.14em; text-transform:uppercase; color:#d4a060; font-style:normal; font-weight:600; }

  /* NARRATIVE BLOCK */
  .tm-about-narrative { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; }
  .tm-about-narrative--reverse .tm-about-narrative__media { order:2; }
  .tm-about-narrative__media { position:relative; overflow:hidden; border-radius:16px; box-shadow:0 40px 80px -20px rgba(74,55,24,.45), 0 16px 40px -8px rgba(74,55,24,.3), 0 4px 12px rgba(26,22,16,.12); background:radial-gradient(circle at 30% 20%,#f8ebd0 0%,#e8d6b0 55%,#c8b48a 100%); }
  .tm-about-narrative__media img { width:100%; height:auto; display:block; mix-blend-mode:multiply; }

  @media (max-width:860px) {
    .tm-about-hero, .tm-about-narrative { grid-template-columns:1fr; gap:32px; padding:64px 16px; }
    .tm-about-values__grid { grid-template-columns:1fr 1fr; }
    .tm-about-timeline__list li { grid-template-columns:1fr; gap:4px; }
    .tm-section { padding:64px 16px; }
  }
  @media (max-width:520px) { .tm-about-values__grid { grid-template-columns:1fr; } }
</style>

<div class="tm-about">
  <!-- HERO -->
  <section class="tm-section--cream" style="padding:0;">
    <div class="tm-about-hero">
      <div>
        <p class="tm-eyebrow">Our story</p>
        <h1 class="tm-h1">Four generations.<br>One leaf.</h1>
        <p class="tm-body">In 1935, our great-grandfather started sourcing tea — tin by tin, estate by estate, refusing anything that didn't meet the nose test. Ninety-one years later, we're still doing it — crafting wellness rituals worth protecting.</p>
        <div style="margin-top:32px;"><a href="/products/premium-collagen-spice-rush-black-tea-blend-revitalizing-energy-with-ginger-cinnamon-cardamom-keto-paleo-friendly-made-in-usa-milled-product-for-smoother-flow" class="tm-btn">Shop Spice Rush<span class="tm-btn__sub">From $6.99</span></a></div>
      </div>
      <div class="tm-about-hero__media">
        <img src="https://res.cloudinary.com/dcwxmxfau/image/upload/f_auto,q_auto,w_1400/Copy_of_M1_rdmzmf.jpg" alt="TMolecule heritage">
