<script type="application/ld+json">                                                                                      
    {{ product | structured_data }}                                                                                        
  </script>
{{ 'tmolecule-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'tmolecule-product.js' | asset_url }}" defer></script>

<div class="tm-page">
  <div class="tm-buybox-wrap">
    <section class="tm-buybox">
      {%- assign featured = product.featured_media -%}
      <div class="tm-buybox__gallery" data-tm-gallery>
        {%- if product.media.size > 1 -%}
          <div class="tm-buybox__thumbs">
            {%- for media in product.media limit: 5 -%}
              <img data-tm-thumb
                   class="{% if forloop.first %}is-active{% endif %}"
                   src="{{ media | image_url: width: 160 }}"
                   data-full="{{ media | image_url: width: 1400 }}"
                   alt="{{ media.alt | escape }}"
                   width="80" height="80" loading="lazy">
            {%- endfor -%}
          </div>
        {%- endif -%}
        <div class="tm-buybox__hero">
          {%- if featured -%}
            <img data-tm-hero
                 src="{{ featured | image_url: width: 1400 }}"
                 alt="{{ featured.alt | escape | default: product.title }}"
                 loading="eager">
          {%- endif -%}
        </div>
      </div>

      <div class="tm-buybox__info">
        {%- if section.settings.label != blank -%}<p class="tm-new">{{ section.settings.label }}</p>{%- endif -%}
        <h1>{{ product.title }}</h1>
        {%- if section.settings.subheadline != blank -%}<p class="tm-sub">{{ section.settings.subheadline }}</p>{%- endif -%}

        {%- comment -%}
          Hardcoded rating block removed — real ratings now come from Judge.me
          star rating app block placed in the customizer. Schema setting
          retained below for backwards compatibility but not rendered.
        {%- endcomment -%}

        {%- assign bullets = section.settings.bullets | split: '|' -%}
        {%- if bullets.size > 0 -%}
          <ul class="tm-buybox__bullets">
            {%- for b in bullets -%}
              <li>{{ b | strip }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {% form 'product', product, class: 'sans', novalidate: 'novalidate' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          {%- assign pack_labels = 'One pack|Two packs|Six packs' | split: '|' -%}
          {%- assign pack_callouts = '||Free shipping' | split: '|' -%}
          <div class="tm-buybox__opts tm-buybox__opts--packs">
            {%- for variant in product.variants limit: 3 -%}
              {%- assign idx = forloop.index0 -%}
              <button type="button" class="tm-pack{% if forloop.first %} is-active{% endif %}"
                      data-tm-variant
                      data-variant-id="{{ variant.id }}"
                      data-variant-price="{{ variant.price | money }}">
                <span class="tm-pack__label">{{ pack_labels[idx] | default: variant.title }}</span>
                <span class="tm-pack__price">{{ variant.price | money }}</span>
                {%- assign callout = pack_callouts[idx] -%}
                {%- if callout != blank -%}
                  <span class="tm-pack__callout">{{ callout }}</span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>

          {%- if section.settings.show_subscribe_toggle and product.selling_plan_groups.size > 0 -%}
            {%- assign plan = product.selling_plan_groups.first.selling_plans.first -%}
            {%- assign discount_label = '' -%}
            {%- if plan.price_adjustments.first -%}
              {%- assign adj = plan.price_adjustments.first -%}
              {%- if adj.value_type == 'percentage' -%}
                {%- assign discount_label = adj.value | append: '% off' -%}
              {%- elsif adj.value_type == 'fixed_amount' -%}
                {%- assign discount_label = adj.value | money | append: ' off' -%}
              {%- endif -%}
            {%- endif -%}
            <div class="tm-buybox__opts tm-buybox__opts--subscribe">
              <button type="button" class="is-active" data-tm-subscribe data-plan-id="">One-time</button>
              <button type="button" data-tm-subscribe data-plan-id="{{ plan.id }}">Subscribe{% if discount_label != '' %} &amp; Save {{ discount_label }}{% endif %}</button>
            </div>
            <input type="hidden" name="selling_plan" value="" data-tm-selling-plan>
          {%- endif -%}

          <p class="tm-buybox__price" data-tm-price>{{ product.selected_or_first_available_variant.price | money }}</p>
          <button type="submit" name="add" class="tm-buybox__cta"
                  {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}Add to cart{% else %}Sold out{% endif %}
          </button>
        {% endform %}

        {%- if section.blocks.size > 0 -%}
          <div class="tm-buybox__badges">
            {%- for block in section.blocks -%}
              {%- if block.type == 'badge' -%}
                <div class="tm-bb" {{ block.shopify_attributes }}>
                  <div class="tm-bb__icon">{{ block.settings.icon }}</div>
                  <span>{{ block.settings.label }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </section>
  </div>
</div>

{% schema %}
{
  "name": "TMolecule product",
  "tag": "section",
  "class": "tm-main-product",
  "blocks": [
    { "type": "@app" },
    { "type": "title", "name": "Title", "limit": 1 },
    { "type": "price", "name": "Price", "limit": 1 },
    { "type": "variant_picker", "name": "Variant picker", "limit": 1 },
    { "type": "buy_buttons", "name": "Buy buttons", "limit": 1 },
    { "type": "badge", "name": "Trust badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji", "default": "✨" },
        { "type": "text", "id": "label", "label": "Label", "default": "Just<br>Launched" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "label", "label": "Top label", "default": "🔥 BESTSELLER" },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline", "default": "A revitalizing daily ritual from a family who has been curating tea blends since 1935." },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating row", "default": true },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.8 · 216 reviews" },
    { "type": "textarea", "id": "bullets", "label": "Bullets (separate with |)",
      "default": "💪 Collagen peptides in every cup — skin, joints, recovery|🌶️ Warming spice blend: ginger, cinnamon, cardamom|🥥 Keto & paleo friendly — zero sugar, zero fillers|👨‍👩‍👧 Family tea heritage since 1935|☕ Milled powder — brews smoother, no bitter edge|🇺🇸 Made in USA" },
    { "type": "checkbox", "id": "show_subscribe_toggle", "label": "Show subscribe toggle", "default": true }
  ]
}
{% endschema %}
