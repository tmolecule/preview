{% comment %}
  TMolecule contact page (OS 2.0)
  Layout: left column intro + direct contact details, right column Shopify contact form.
{% endcomment %}

<div class="tm-page">
  <section class="tm-band tm-band--cream">
    <div class="tm-contact">
      <div class="tm-contact__intro">
        {%- if section.settings.eyebrow != blank -%}<p class="tm-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h1 class="tm-h1">{{ section.settings.heading }}</h1>{%- endif -%}
        {%- if section.settings.body != blank -%}<div class="rte">{{ section.settings.body }}</div>{%- endif -%}
        <ul class="tm-contact__details">
          {%- if section.settings.email != blank -%}
            <li><strong>Email</strong><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></li>
          {%- endif -%}
          {%- if section.settings.phone != blank -%}
            <li><strong>Phone</strong><a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}">{{ section.settings.phone }}</a></li>
          {%- endif -%}
          {%- if section.settings.hours != blank -%}
            <li><strong>Hours</strong><span>{{ section.settings.hours }}</span></li>
          {%- endif -%}
          {%- if section.settings.address != blank -%}
            <li><strong>Mailing</strong><span>{{ section.settings.address }}</span></li>
          {%- endif -%}
        </ul>
      </div>
      <div class="tm-contact__form">
        {%- form 'contact', id: 'tm-contact-form', class: 'tm-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="tm-form__success"><p>Thank you — we'll get back to you within one business day.</p></div>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="tm-form__errors">
              <p>{{ 'templates.contact.form.error_heading' | t }}</p>
              <ul>
                {%- for error in form.errors -%}
                  <li>{{ form.errors.messages[error] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
          <label>
            <span>Name</span>
            <input type="text" name="contact[{{ 'templates.contact.form.name' | t }}]" value="{%- if form.name -%}{{ form.name }}{%- elsif customer -%}{{ customer.name }}{%- endif -%}" required>
          </label>
          <label>
            <span>Email</span>
            <input type="email" name="contact[email]" value="{%- if form.email -%}{{ form.email }}{%- elsif customer -%}{{ customer.email }}{%- endif -%}" required>
          </label>
          <label>
            <span>Phone (optional)</span>
            <input type="tel" name="contact[{{ 'templates.contact.form.phone' | t }}]" value="{{ form.phone }}">
          </label>
          <label>
            <span>Message</span>
            <textarea name="contact[body]" rows="6" required>{{ form.body }}</textarea>
          </label>
          <button type="submit" class="tm-inline-cta">Send message</button>
        {%- endform -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "TMolecule contact",
  "tag": "section",
  "class": "tm-contact-section",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    { "type":"text", "id":"eyebrow", "label":"Eyebrow", "default":"Get in touch" },
    { "type":"text", "id":"heading", "label":"Heading", "default":"We'd love to hear from you" },
    { "type":"richtext", "id":"body", "label":"Intro body", "default":"<p>Questions about your order, wholesale inquiries, or want to collaborate? Drop us a note and we'll reply within one business day.</p>" },
    { "type":"text", "id":"email", "label":"Email", "default":"hello@tmolecule.com" },
    { "type":"text", "id":"phone", "label":"Phone" },
    { "type":"text", "id":"hours", "label":"Hours", "default":"Mon–Fri · 9am–5pm ET" },
    { "type":"text", "id":"address", "label":"Mailing address" }
  ],
  "presets": [{ "name":"TMolecule contact" }]
}
{% endschema %}
