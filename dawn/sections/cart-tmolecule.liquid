  function fire(){
    var preset = (document.body.dataset.tmPreset || 'default').trim();
    var shapes = S[preset] || S['default'];
    var layer = document.createElement('div');
    layer.className = 'tm-confetti-layer';
    layer.setAttribute('aria-hidden', 'true');
    document.body.appendChild(layer);

    var count = 48;
    for (var i = 0; i < count; i++) {
      var piece = document.createElement('div');
      piece.className = 'tm-confetti-piece';
      var url = shapes[Math.floor(Math.random() * shapes.length)];
      piece.style.backgroundImage = 'url("' + url + '")';
      var size = 14 + Math.random() * 14;
      piece.style.width = size + 'px';
      piece.style.height = size + 'px';
      piece.style.left = (Math.random() * 100) + '%';
      piece.style.setProperty('--dur', (2.6 + Math.random() * 2.4) + 's');
      piece.style.setProperty('--drift', ((Math.random() * 260) - 130) + 'px');
      piece.style.setProperty('--spin', ((Math.random() * 1080) - 540) + 'deg');
      piece.style.animationDelay = (Math.random() * 0.4) + 's';
      layer.appendChild(piece);
    }
    // Clean up after all pieces have finished (max 5.5s)
    setTimeout(function(){ if (layer && layer.parentNode) layer.parentNode.removeChild(layer); }, 5800);
  }

  function check(){
    var activated = document.querySelector('.tm-cart__offer--activated');
    var flag = 'tm_cart_celebrated';
    if (activated) {
      try {
        var already = sessionStorage.getItem(flag);
        if (!already) {
          sessionStorage.setItem(flag, '1');
          // Defer slightly so the page has painted
          setTimeout(fire, 250);
        }
      } catch(e) { fire(); }
    } else {
      try { sessionStorage.removeItem(flag); } catch(e) {}
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', check);
  } else {
    check();
  }
})();
</script>

