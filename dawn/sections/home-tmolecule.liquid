<style>
  .tm-home { --ink:#1a1816; --cream:#f8f4eb; --sand:#e9dfcf; --warm:#d7ceb2; --terra:#c87040; --terra-dark:#a85830; --espresso:#1a1610; color:var(--ink); font-family:'Fraunces', Georgia, serif; }
  .tm-home img { max-width:100%; display:block; }
  .tm-home .sans { font-family:'Inter', system-ui, sans-serif; }
  .tm-section { padding:100px 24px; position:relative; overflow:hidden; }
  .tm-section__inner { max-width:1200px; margin:0 auto; position:relative; z-index:1; }
  .tm-section--cream { background:var(--cream); }
  .tm-section--sand { background:var(--sand); }
  .tm-section--dark { background:var(--espresso); color:#f5ecd8; }
  .tm-section--terra { background:linear-gradient(135deg,#c87040 0%,#a85830 50%,#884020 100%); color:#faf3e0; }
  .tm-section--hero { background:linear-gradient(135deg,#faf6ec 0%,#ede0c4 60%,#d7ceb2 100%); padding:0; }
  .tm-h1 { font-size:clamp(42px,6vw,80px); line-height:1.0; letter-spacing:-.03em; font-weight:700; margin:0 0 20px; }
  .tm-h2 { font-size:clamp(32px,4.5vw,56px); line-height:1.05; letter-spacing:-.02em; font-weight:700; margin:0 0 16px; }
  .tm-eyebrow { text-transform:uppercase; letter-spacing:.18em; font-size:11px; color:var(--terra); margin:0 0 12px; font-family:'Inter'; font-weight:700; }
  .tm-body { font-family:'Inter'; font-size:17px; line-height:1.65; opacity:.85; max-width:55ch; }
  .tm-section--dark .tm-eyebrow { color:#d4a060; }
  .tm-section--terra .tm-eyebrow { color:#fce8d0; }
  .tm-section--dark .tm-h2 { color:#f5ecd8; }
  .tm-btn { display:inline-flex; align-items:center; gap:8px; padding:18px 44px; background:var(--terra); color:#fff; border:0; border-radius:14px; font-family:'Inter'; font-size:15px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; text-decoration:none; cursor:pointer; box-shadow:0 6px 20px rgba(200,112,64,.35); transition:all .2s ease; }
  .tm-btn:hover { transform:translateY(-2px); box-shadow:0 10px 30px rgba(200,112,64,.45); background:var(--terra-dark); }
  .tm-btn--dark { background:var(--espresso); box-shadow:0 6px 20px rgba(26,22,16,.3); }
  .tm-btn__sub { display:block; font-size:11px; font-weight:500; opacity:.8; margin-top:2px; letter-spacing:.08em; }
  .tm-section--dark .tm-btn { background:var(--terra); }
  .tm-section--terra .tm-btn { background:var(--espresso); box-shadow:0 6px 20px rgba(26,22,16,.4); }
  .tm-home-hero { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1.05fr 1fr; gap:64px; align-items:center; padding:80px 24px; }
  .tm-home-hero__copy { display:flex; flex-direction:column; justify-content:center; }
  .tm-home-hero__media { position:relative; overflow:hidden; border-radius:16px; box-shadow:0 40px 80px -20px rgba(74,55,24,.45), 0 16px 40px -8px rgba(74,55,24,.3), 0 4px 12px rgba(26,22,16,.12); background:radial-gradient(circle at 30% 20%,#f8ebd0 0%,#e8d6b0 55%,#c8b48a 100%); }
  .tm-home-hero__media img { width:100%; height:auto; display:block; mix-blend-mode:multiply; }
  .tm-home-hero__cta { display:flex; gap:16px; align-items:center; flex-wrap:wrap; margin-top:36px; }
  .tm-home-trust { padding:0; overflow:hidden; border-top:1px solid rgba(26,22,16,.1); border-bottom:1px solid rgba(26,22,16,.1); -webkit-mask-image:linear-gradient(90deg,transparent,#000 6%,#000 94%,transparent); background:linear-gradient(180deg,#d7ceb2 0%,#c3b590 100%); }
  .tm-home-trust__track { display:flex; gap:56px; width:max-content; padding:22px 0; animation:tm-marquee 36s linear infinite; }
  .tm-home-trust__item { display:flex; align-items:center; gap:10px; flex-shrink:0; font-family:'Inter'; font-size:13px; font-weight:600; letter-spacing:.06em; text-transform:uppercase; white-space:nowrap; color:var(--ink); opacity:.7; }
  .tm-home-trust__item .dot { color:var(--terra); font-size:8px; }
  @keyframes tm-marquee { 0%{transform:translate(0)} to{transform:translate(-50%)} }
  .tm-home-featured { display:grid; grid-template-columns:1.1fr 1fr; gap:80px; align-items:center; }
  .tm-home-featured__media { border-radius:16px; overflow:hidden; box-shadow:0 40px 80px -20px rgba(74,55,24,.45), 0 16px 40px -8px rgba(74,55,24,.3), 0 4px 12px rgba(26,22,16,.12); background:radial-gradient(circle at 30% 20%,#f8ebd0 0%,#e8d6b0 55%,#c8b48a 100%); }
  .tm-home-featured__media img { width:100%; mix-blend-mode:multiply; }
  .tm-home-featured__price { font-size:36px; font-weight:800; margin:20px 0 28px; color:var(--terra); }
  .tm-facts { text-align:center; }
  .tm-facts__bar { display:grid; grid-template-columns:repeat(9,1fr); gap:8px; margin:40px 0 64px; padding:24px 12px; background:rgba(255,255,255,.5); border-radius:16px; box-shadow:0 40px 80px -20px rgba(74,55,24,.45), 0 16px 40px -8px rgba(74,55,24,.3), 0 4px 12px rgba(26,22,16,.12); }
  .tm-facts__chip { display:flex; flex-direction:column; align-items:center; padding:14px 6px; background:linear-gradient(180deg,#fdf6e6 0%,#f5e9d0 100%); border-radius:12px; box-shadow:0 10px 20px -4px rgba(74,55,24,.25), 0 4px 8px -2px rgba(74,55,24,.18), 0 1px 3px rgba(26,22,16,.1); transition:transform .2s ease, box-shadow .2s ease; }
  .tm-facts__chip:hover { transform:translateY(-3px); box-shadow:0 16px 28px -4px rgba(74,55,24,.35), 0 8px 12px -2px rgba(74,55,24,.22), 0 2px 4px rgba(26,22,16,.12); }
  .tm-facts__chip__icon { display:flex; align-items:center; justify-content:center; width:48px; height:48px; margin-bottom:12px; flex-shrink:0; }
  .tm-facts__chip__icon img, .tm-facts__chip__icon svg { max-width:100%; max-height:100%; width:auto; height:auto; display:block; object-fit:contain; }
  .tm-facts__chip span { font-family:'Inter'; font-size:11px; font-weight:600; letter-spacing:.02em; color:var(--ink); line-height:1.25; text-align:center; min-height:2.5em; display:flex; align-items:flex-start; justify-content:center; }
  .tm-facts__grid { display:grid; grid-template-columns:repeat(3,1fr); gap:28px; margin-top:16px; }
  .tm-facts__card { background:var(--cream); border-radius:16px; padding:48px 28px 40px; text-align:center; box-shadow:0 40px 80px -20px rgba(74,55,24,.45), 0 16px 40px -8px rgba(74,55,24,.3), 0 4px 12px rgba(26,22,16,.12); transition:transform .2s ease; position:relative; }
  .tm-facts__card:hover { transform:translateY(-4px); }
  .tm-facts__card img { height:80px; width:auto; margin:0 auto 24px; padding:12px; background:var(--sand); border-radius:12px; }
  .tm-facts__card--featured { background:linear-gradient(160deg,#fdf4dc 0%,#f5e2b8 100%); border:2px solid var(--terra); box-shadow:0 50px 100px -20px rgba(200,112,64,.45), 0 20px 48px -8px rgba(200,112,64,.3), 0 4px 12px rgba(26,22,16,.15); }
  .tm-facts__card--featured img { height:80px; padding:14px; background:linear-gradient(135deg,#ffd89c 0%,#e8a860 100%); border-radius:12px; box-shadow:0 8px 20px rgba(200,112,64,.35); margin-top:8px; }
  .tm-facts__card--featured h3 { color:var(--terra-dark); }
  .tm-facts__card__badge { position:absolute; top:-14px; left:50%; transform:translateX(-50%); background:var(--terra); color:#fff; font-family:'Inter'; font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; padding:6px 16px; border-radius:100px; box-shadow:0 4px 12px rgba(200,112,64,.4); white-space:nowrap; z-index:2; }
  .tm-facts__card h3 { font-size:20px; font-weight:700; margin:0 0 10px; font-family:'Fraunces',Georgia,serif; }
  .tm-facts__card p { font-family:'Inter'; font-size:15px; line-height:1.6; opacity:.8; margin:0; }
  .tm-home-heritage { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; padding:100px 24px; }
  .tm-home-heritage__media { position:relative; overflow:hidden; border-radius:16px; box-shadow:0 40px 80px -20px rgba(74,55,24,.45), 0 16px 40px -8px rgba(74,55,24,.3), 0 4px 12px rgba(26,22,16,.12); background:radial-gradient(circle at 30% 20%,#f8ebd0 0%,#e8d6b0 55%,#c8b48a 100%); }
  .tm-home-heritage__media img { width:100%; height:auto; display:block; mix-blend-mode:multiply; filter:drop-shadow(0 8px 16px rgba(26,22,16,.25)); }
  .tm-home-heritage__sig { font-style:italic; margin-top:20px; opacity:.7; color:var(--terra); font-family:'Inter'; }
  .tm-home-philosophy { text-align:center; padding:120px 24px; max-width:1200px; margin:0 auto; }
  .tm-home-philosophy .tm-h2 { max-width:16ch; margin:0 auto 24px; }
  .tm-home-philosophy .tm-body { max-width:60ch; margin:0 auto; }
  .tm-home-reviews { text-align:center; }
  .tm-home-reviews__grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-top:40px; text-align:left; }
  .tm-home-reviews__card { background:rgba(248,244,235,.08); border:1px solid rgba(212,160,96,.15); border-radius:16px; padding:32px 24px; }
  .tm-home-reviews__card p { font-size:17px; line-height:1.55; margin:0 0 16px; color:#f5ecd8; font-family:'Fraunces',Georgia,serif; }
  .tm-home-reviews__card cite { font-style:normal; font-family:'Inter'; font-size:13px; color:#d4a060; font-weight:600; letter-spacing:.04em; text-transform:uppercase; }
  .tm-home-science { text-align:center; }
  @media (max-width:860px) {
    .tm-home-hero, .tm-home-featured, .tm-home-heritage { grid-template-columns:1fr; gap:32px; padding:64px 16px; }
    .tm-facts__bar { grid-template-columns:repeat(5,1fr); }
    .tm-facts__grid, .tm-home-reviews__grid { grid-template-columns:1fr; }
    .tm-section { padding:64px 16px; }
  }
  @media (max-width:520px) { .tm-facts__bar { grid-template-columns:repeat(3,1fr); } }
</style>

<div class="tm-home">
  {%- assign product_url = section.settings.product_url | default: '/collections/all' -%}
  {%- assign hero_image = section.settings.hero_image_url | default: 'https://res.cloudinary.com/dcwxmxfau/image/upload/f_auto,q_auto,w_1400/Copy_of_Artboard_1_ldyjej.jpg' -%}

  <!-- HERO -->
