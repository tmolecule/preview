  <!-- HERITAGE -->
  <section class="tm-section--cream" style="padding:0;">
    <div class="tm-home-heritage">
      <div class="tm-home-heritage__media">
        <img src="https://res.cloudinary.com/dcwxmxfau/image/upload/f_auto,q_auto,w_1400/Copy_of_M1_rdmzmf.jpg" alt="" width="1400" height="900">
