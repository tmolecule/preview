{% comment %}
  TMolecule homepage — hero, trust row, featured product, heritage, USP grid, testimonials.
{% endcomment %}

<div class="tm-page">
  {%- for block in section.blocks -%}
    {%- case block.type -%}

    {%- when 'hero' -%}
      <div class="tm-band tm-band--cream" {{ block.shopify_attributes }}>
        <div class="tm-home-hero">
          <div class="tm-home-hero__copy">
            {%- if block.settings.eyebrow != blank -%}<p class="tm-eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
            {%- if block.settings.heading != blank -%}<h1 class="tm-h1">{{ block.settings.heading }}</h1>{%- endif -%}
            {%- if block.settings.body != blank -%}<div class="rte tm-home-hero__body">{{ block.settings.body }}</div>{%- endif -%}
            <div class="tm-home-hero__cta">
              {%- if block.settings.cta_label != blank -%}
                <a href="{{ block.settings.cta_link | default: '/collections/all' }}" class="tm-inline-cta">{{ block.settings.cta_label }}{%- if block.settings.cta_sub != blank -%}<span class="tm-inline-cta__sub">{{ block.settings.cta_sub }}</span>{%- endif -%}</a>
              {%- endif -%}
              {%- if block.settings.secondary_label != blank -%}
                <a href="{{ block.settings.secondary_link | default: '/pages/about' }}" class="tm-link-cta">{{ block.settings.secondary_label }} →</a>
              {%- endif -%}
            </div>
          </div>
          {%- if block.settings.image != blank -%}
            <div class="tm-home-hero__media"><img src="{{ block.settings.image | image_url: width: 1400 }}" alt="{{ block.settings.image.alt | escape }}" loading="eager" fetchpriority="high"></div>
          {%- endif -%}
        </div>
      </div>

    {%- when 'trust' -%}
      <div class="tm-band tm-band--sand" {{ block.shopify_attributes }}>
        <div class="tm-trust">
          <div class="tm-trust__track">
            {%- for i in (1..6) -%}
              {%- assign ic = 'icon_' | append: i -%}
              {%- assign lb = 'label_' | append: i -%}
              {%- if block.settings[lb] != blank -%}
                <div class="tm-trust__item"><div class="tm-badge">{{ block.settings[ic] }}</div><span>{{ block.settings[lb] }}</span></div>
              {%- endif -%}
            {%- endfor -%}
            {%- for i in (1..6) -%}
              {%- assign ic = 'icon_' | append: i -%}
              {%- assign lb = 'label_' | append: i -%}
              {%- if block.settings[lb] != blank -%}
                <div class="tm-trust__item"><div class="tm-badge">{{ block.settings[ic] }}</div><span>{{ block.settings[lb] }}</span></div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

    {%- when 'featured' -%}
      {%- assign featured = all_products[block.settings.product] -%}
      <div class="tm-band tm-band--honey" {{ block.shopify_attributes }}>
        <div class="tm-featured">
          <div class="tm-featured__media">
            {%- if featured != blank and featured.featured_image != blank -%}
              <img src="{{ featured.featured_image | image_url: width: 900 }}" alt="{{ featured.title | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="tm-featured__copy">
            {%- if block.settings.eyebrow != blank -%}<p class="tm-eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
            {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- elsif featured != blank -%}<h2 class="tm-h2">{{ featured.title }}</h2>{%- endif -%}
            <div class="rte">{{ block.settings.body }}</div>
            {%- if featured != blank -%}
              <p class="tm-featured__price">{{ featured.price | money }}</p>
              <a href="{{ featured.url }}" class="tm-inline-cta">{{ block.settings.cta_label | default: 'Shop now' }}{%- if block.settings.cta_sub != blank -%}<span class="tm-inline-cta__sub">{{ block.settings.cta_sub }}</span>{%- endif -%}</a>
            {%- endif -%}
          </div>
        </div>
      </div>

    {%- when 'usp' -%}
      <div class="tm-band tm-band--deep-sand" {{ block.shopify_attributes }}>
        <div class="tm-usp">
          {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
          <div class="tm-usp__grid">
            {%- for i in (1..3) -%}
              {%- assign t = 'title_' | append: i -%}
              {%- assign b = 'body_' | append: i -%}
              {%- assign ic = 'icon_' | append: i -%}
              {%- if block.settings[t] != blank -%}
                <div class="tm-usp__card">
                  {%- if block.settings[ic] != blank -%}<div class="tm-usp__icon">{{ block.settings[ic] }}</div>{%- endif -%}
                  <h3>{{ block.settings[t] }}</h3>
                  <p>{{ block.settings[b] }}</p>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

    {%- when 'heritage' -%}
      <div class="tm-band tm-band--cream" {{ block.shopify_attributes }}>
        <div class="tm-heritage">
          {%- if block.settings.image != blank -%}
            <div class="tm-heritage__media"><img src="{{ block.settings.image | image_url: width: 1400 }}" alt=""></div>
          {%- endif -%}
          <div class="tm-heritage__copy">
            {%- if block.settings.eyebrow != blank -%}<p class="tm-eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
            {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
            <div class="rte">{{ block.settings.body }}</div>
            {%- if block.settings.cta_label != blank -%}
              <div class="tm-cta-wrap" style="text-align:left;"><a href="{{ block.settings.cta_link | default: '/pages/about' }}" class="tm-inline-cta">{{ block.settings.cta_label }}{%- if block.settings.cta_sub != blank -%}<span class="tm-inline-cta__sub">{{ block.settings.cta_sub }}</span>{%- endif -%}</a></div>
            {%- endif -%}
          </div>
        </div>
      </div>

    {%- when 'reviews' -%}
      <div class="tm-band tm-band--espresso" {{ block.shopify_attributes }}>
        <div class="tm-reviews">
          {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
          <div class="tm-reviews__grid">
            {%- for n in (1..3) -%}
              {%- assign q = 'quote_' | append: n -%}
              {%- assign a = 'author_' | append: n -%}
              {%- if block.settings[q] != blank -%}
                <blockquote><p>"{{ block.settings[q] }}"</p><cite>— {{ block.settings[a] }}</cite></blockquote>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

    {%- endcase -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "TMolecule home",
  "tag": "section",
  "class": "tm-home-section",
  "enabled_on": { "templates": ["index"] },
  "settings": [],
  "blocks": [
    { "type":"hero", "name":"Hero", "limit":1, "settings":[
      {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Heritage since 1935"},
      {"type":"text","id":"heading","label":"Heading","default":"Tea that earns its place in your morning."},
      {"type":"richtext","id":"body","label":"Body","default":"<p>Bold milled black tea, collagen peptides, and three warming spices. One scoop, hot water, thirty seconds.</p>"},
      {"type":"image_picker","id":"image","label":"Hero image"},
      {"type":"text","id":"cta_label","label":"Primary CTA","default":"Shop Spice Rush"},
      {"type":"text","id":"cta_sub","label":"Primary CTA sublabel","default":"From $6.99"},
      {"type":"url","id":"cta_link","label":"Primary CTA link"},
      {"type":"text","id":"secondary_label","label":"Secondary CTA","default":"Our story"},
      {"type":"url","id":"secondary_link","label":"Secondary CTA link"}
    ]},
    { "type":"trust", "name":"Trust marquee", "limit":1, "settings":[
      {"type":"text","id":"icon_1","label":"Icon 1","default":"👨‍👩‍👧"}, {"type":"text","id":"label_1","label":"Label 1","default":"Family heritage since 1935"},
      {"type":"text","id":"icon_2","label":"Icon 2","default":"💪"}, {"type":"text","id":"label_2","label":"Label 2","default":"Collagen peptides"},
      {"type":"text","id":"icon_3","label":"Icon 3","default":"🥥"}, {"type":"text","id":"label_3","label":"Label 3","default":"Keto & paleo friendly"},
      {"type":"text","id":"icon_4","label":"Icon 4","default":"🇺🇸"}, {"type":"text","id":"label_4","label":"Label 4","default":"Made in USA"},
      {"type":"text","id":"icon_5","label":"Icon 5","default":"🌶️"}, {"type":"text","id":"label_5","label":"Label 5","default":"Real whole spices"},
      {"type":"text","id":"icon_6","label":"Icon 6","default":"🧂"}, {"type":"text","id":"label_6","label":"Label 6","default":"Milled for a uniform blend"}
    ]},
    { "type":"featured", "name":"Featured product", "limit":1, "settings":[
      {"type":"product","id":"product","label":"Product"},
      {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Our bestseller"},
      {"type":"text","id":"heading","label":"Heading (optional — falls back to product title)"},
      {"type":"richtext","id":"body","label":"Body","default":"<p>Spice Rush is a revitalizing black tea blend built on four generations of tea-sourcing know-how. Bold milled black tea, hydrolyzed collagen peptides, and three warming spices: ginger, cinnamon, and cardamom.</p>"},
      {"type":"text","id":"cta_label","label":"CTA label","default":"Try Spice Rush"},
      {"type":"text","id":"cta_sub","label":"CTA sublabel","default":"Free shipping over $35"}
    ]},
    { "type":"usp", "name":"USP grid", "limit":1, "settings":[
      {"type":"text","id":"heading","label":"Heading","default":"Why Spice Rush works"},
      {"type":"text","id":"icon_1","label":"Icon 1","default":"☕"}, {"type":"text","id":"title_1","label":"Title 1","default":"Thirty seconds to a cup"}, {"type":"text","id":"body_1","label":"Body 1","default":"No steeping, no strainer, no timer. One scoop, hot water, stir."},
      {"type":"text","id":"icon_2","label":"Icon 2","default":"💪"}, {"type":"text","id":"title_2","label":"Title 2","default":"Protein in every cup"}, {"type":"text","id":"body_2","label":"Body 2","default":"Hydrolyzed collagen peptides for skin, joints, and recovery — in the cup you were going to drink anyway."},
      {"type":"text","id":"icon_3","label":"Icon 3","default":"🌶️"}, {"type":"text","id":"title_3","label":"Title 3","default":"Real spices, nothing else"}, {"type":"text","id":"body_3","label":"Body 3","default":"Whole ginger, Ceylon cinnamon, green cardamom — milled in-house. Zero sugar, zero fillers."}
    ]},
    { "type":"heritage", "name":"Heritage block", "limit":1, "settings":[
      {"type":"image_picker","id":"image","label":"Image"},
      {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Heritage since 1935"},
      {"type":"text","id":"heading","label":"Heading","default":"Four generations. One leaf."},
      {"type":"richtext","id":"body","label":"Body","default":"<p>In 1935, our great-grandfather started sourcing tea — tin by tin, estate by estate, refusing anything that didn't meet the nose test. Ninety-one years later, we're still doing it.</p>"},
      {"type":"text","id":"cta_label","label":"CTA label","default":"Our story"},
      {"type":"text","id":"cta_sub","label":"CTA sublabel"},
      {"type":"url","id":"cta_link","label":"CTA link"}
    ]},
    { "type":"reviews", "name":"Reviews", "limit":1, "settings":[
      {"type":"text","id":"heading","label":"Heading","default":"What sippers say"},
      {"type":"textarea","id":"quote_1","label":"Quote 1","default":"I swapped my 11am coffee for a Spice Rush and my afternoons got their focus back. Plus — collagen. Win-win."},
      {"type":"text","id":"author_1","label":"Author 1","default":"Marielle S., verified buyer"},
      {"type":"textarea","id":"quote_2","label":"Quote 2","default":"Tastes like real chai, not a sugar bomb. My daily cup. The cardamom is so bright."},
      {"type":"text","id":"author_2","label":"Author 2","default":"David R., verified buyer"},
      {"type":"textarea","id":"quote_3","label":"Quote 3","default":"30 seconds to brew, no strainer, no mess. Finally a clean-label collagen drink I actually enjoy."},
      {"type":"text","id":"author_3","label":"Author 3","default":"Aisha K., verified buyer"}
    ]}
  ],
  "presets": [
    { "name":"TMolecule home", "blocks":[
      {"type":"hero"},{"type":"trust"},{"type":"featured"},{"type":"usp"},{"type":"heritage"},{"type":"reviews"}
    ]}
  ]
}
{% endschema %}
