          <a href="{{ product_url }}" class="tm-btn">{{ section.settings.hero_cta | default: 'Shop Spice Rush' }}<span class="tm-btn__sub">{{ section.settings.hero_cta_sub | default: 'From $6.99' }}</span></a>
