    { "type": "disclaimer", "name": "FDA disclaimer", "limit": 1, "settings": [
      {"type":"textarea","id":"body","label":"Disclaimer text","default":"* These statements have not been evaluated by the Food and Drug Administration. This product is not intended to diagnose, treat, cure, or prevent any disease. Consult your healthcare provider before use if you are pregnant, nursing, taking medication, or have a medical condition. Individual results may vary."}
    ]},
    { "type": "reviews", "name": "Reviews", "limit": 1, "settings": [
      {"type":"text","id":"heading","label":"Heading","default":"What sippers say"},
      {"type":"textarea","id":"quote_1","label":"Quote 1"}, {"type":"text","id":"author_1","label":"Author 1"},
      {"type":"textarea","id":"quote_2","label":"Quote 2"}, {"type":"text","id":"author_2","label":"Author 2"},
      {"type":"textarea","id":"quote_3","label":"Quote 3"}, {"type":"text","id":"author_3","label":"Author 3"},
      {"type":"text","id":"cta_label","label":"CTA label (optional)","default":"Join the ritual"},
      {"type":"text","id":"cta_sub","label":"CTA sublabel"},
      {"type":"url","id":"cta_link","label":"CTA link"}
    ]}
  ],
  "presets": [
    { "name":"TMolecule story", "blocks":[
      {"type":"trust_marquee"},{"type":"tabs"},{"type":"ingredient_grid"},{"type":"heritage"},{"type":"compare"},
      {"type":"editorial","settings":{"band":"deep-sand"}},{"type":"editorial","settings":{"band":"honey","reverse":true}},
