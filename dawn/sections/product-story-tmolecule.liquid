      {"type":"text","id":"heading","label":"Heading","default":"What's in the scoop"},
      {"type":"text","id":"subhead","label":"Subhead","default":"Five ingredients. Nothing else."},
      {"type":"image_picker","id":"img_1","label":"Card 1 image"}, {"type":"text","id":"title_1","label":"Title 1"}, {"type":"text","id":"body_1","label":"Body 1"},
      {"type":"image_picker","id":"img_2","label":"Card 2 image"}, {"type":"text","id":"title_2","label":"Title 2"}, {"type":"text","id":"body_2","label":"Body 2"},
      {"type":"image_picker","id":"img_3","label":"Card 3 image"}, {"type":"text","id":"title_3","label":"Title 3"}, {"type":"text","id":"body_3","label":"Body 3"},
      {"type":"image_picker","id":"img_4","label":"Card 4 image"}, {"type":"text","id":"title_4","label":"Title 4"}, {"type":"text","id":"body_4","label":"Body 4"},
      {"type":"image_picker","id":"img_5","label":"Card 5 image"}, {"type":"text","id":"title_5","label":"Title 5"}, {"type":"text","id":"body_5","label":"Body 5"},
      {"type":"image_picker","id":"img_6","label":"Card 6 image"}, {"type":"text","id":"title_6","label":"Title 6"}, {"type":"text","id":"body_6","label":"Body 6"},
      {"type":"text","id":"cta_label","label":"CTA label (optional)","default":"Try Spice Rush"},
      {"type":"text","id":"cta_sub","label":"CTA sublabel","default":"Starting at $6.99"},
      {"type":"url","id":"cta_link","label":"CTA link"}
    ]},
    { "type": "heritage", "name": "Heritage", "settings": [
      {"type":"image_picker","id":"image","label":"Image"},
      {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Heritage since 1935"},
      {"type":"text","id":"heading","label":"Heading","default":"Four generations. One leaf."},
      {"type":"richtext","id":"body","label":"Body"},
