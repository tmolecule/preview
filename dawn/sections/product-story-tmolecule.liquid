{{ 'tmolecule-product.css' | asset_url | stylesheet_tag }}

{%- capture leaf_svg -%}<svg class="tm-ing__flourish tm-ing__flourish--tl" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><g fill="currentColor"><path d="M100 20c-30 10-55 35-65 70-5 20-3 42 8 60 3-22 14-44 33-60 14-12 30-22 42-36 0 0 4-24-18-34zm0 8c12 4 13 18 13 26-10 12-24 20-36 30-18 16-28 36-32 56-6-14-6-30-2-46 10-30 32-54 57-66z"/><path d="M60 130c-6 14-12 28-14 44 12-6 23-16 30-29 10-18 12-38 12-60-14 14-22 30-28 45z"/></g></svg>{%- endcapture -%}

<div class="tm-page">
  <section class="tm-story">
    {%- for block in section.blocks -%}
      {%- case block.type -%}

      {%- when 'trust_marquee' -%}
        <div class="tm-band tm-band--sand" {{ block.shopify_attributes }}>
          <div class="tm-trust">
            <div class="tm-trust__track">
              {%- for i in (1..2) -%}
                {%- for n in (1..6) -%}
                  {%- assign ico = 'icon_' | append: n -%}
                  {%- assign lbl = 'label_' | append: n -%}
                  {%- if block.settings[lbl] != blank -%}
                    <div class="tm-trust__item"><div class="tm-badge">{{ block.settings[ico] }}</div><span>{{ block.settings[lbl] }}</span></div>
                  {%- endif -%}
                {%- endfor -%}
              {%- endfor -%}
            </div>
          </div>
        </div>

      {%- when 'tabs' -%}
        <div class="tm-band tm-band--cream" {{ block.shopify_attributes }}>
          <div class="tm-tabs">
            {%- for n in (1..4) -%}
              {%- assign t = 'tab' | append: n | append: '_title' -%}
              {%- assign b = 'tab' | append: n | append: '_body' -%}
              {%- if block.settings[t] != blank -%}
                <details {% if forloop.first %}open{% endif %}>
                  <summary>{{ block.settings[t] }}</summary>
                  <div class="tm-tabs__body rte">{{ block.settings[b] }}</div>
                </details>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

      {%- when 'ingredient_grid' -%}
        <div class="tm-band tm-band--sand" {{ block.shopify_attributes }}>
          <div class="tm-ing">
            {{ leaf_svg }}
            {%- assign leaf_svg_br = leaf_svg | replace: 'tm-ing__flourish--tl', 'tm-ing__flourish--br' -%}
            {{ leaf_svg_br }}
            {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
            {%- if block.settings.subhead != blank -%}<p class="tm-sub">{{ block.settings.subhead }}</p>{%- endif -%}
            <div class="tm-ing__grid">
              {%- for n in (1..6) -%}
                {%- assign img = 'img_' | append: n -%}
                {%- assign ttl = 'title_' | append: n -%}
                {%- assign body = 'body_' | append: n -%}
                {%- if block.settings[ttl] != blank -%}
                  <div class="tm-ing__card">
                    {%- if block.settings[img] != blank -%}
                      <img src="{{ block.settings[img] | image_url: width: 600 }}" alt="" loading="lazy">
                    {%- endif -%}
                    <h3>{{ block.settings[ttl] }}</h3>
                    <p>{{ block.settings[body] }}</p>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
            {%- if block.settings.cta_label != blank -%}
              <div class="tm-cta-wrap"><a href="{{ block.settings.cta_link | default: '#' }}" class="tm-inline-cta">{{ block.settings.cta_label }}{%- if block.settings.cta_sub != blank -%}<span class="tm-inline-cta__sub">{{ block.settings.cta_sub }}</span>{%- endif -%}</a></div>
            {%- endif -%}
          </div>
        </div>

      {%- when 'heritage' -%}
        <div class="tm-band tm-band--honey" {{ block.shopify_attributes }}>
          <div class="tm-heritage">
            <div class="tm-heritage__media">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 1400 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy">
              {%- endif -%}
            </div>
            <div class="tm-heritage__copy">
              {%- if block.settings.eyebrow != blank -%}<p class="tm-eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
              {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
              <div class="rte">{{ block.settings.body }}</div>
              {%- if block.settings.signature != blank -%}<p class="tm-sig">{{ block.settings.signature }}</p>{%- endif -%}
              {%- if block.settings.cta_label != blank -%}
                <div class="tm-cta-wrap" style="text-align:left;"><a href="{{ block.settings.cta_link | default: '#' }}" class="tm-inline-cta">{{ block.settings.cta_label }}{%- if block.settings.cta_sub != blank -%}<span class="tm-inline-cta__sub">{{ block.settings.cta_sub }}</span>{%- endif -%}</a></div>
              {%- endif -%}
            </div>
          </div>
        </div>

      {%- when 'compare' -%}
        <div class="tm-band tm-band--cream" {{ block.shopify_attributes }}>
          <div class="tm-compare">
            {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
            <table>
              <thead><tr><th></th><th>{{ block.settings.us_label }}</th><th>{{ block.settings.them_label }}</th></tr></thead>
              <tbody>
                {%- for n in (1..6) -%}
                  {%- assign row = 'row_' | append: n -%}
                  {%- assign ico = 'ico_' | append: n -%}
                  {%- assign us = 'us_' | append: n -%}
                  {%- assign them = 'them_' | append: n -%}
                  {%- if block.settings[row] != blank -%}
                    <tr>
                      <td><span class="tm-compare__ico">{{ block.settings[ico] }}</span>{{ block.settings[row] }}</td>
                      <td class="tm-compare__us"><span class="tm-yes">✓</span>{{ block.settings[us] }}</td>
                      <td class="tm-compare__them"><span class="tm-no">✕</span>{{ block.settings[them] }}</td>
                    </tr>
                  {%- endif -%}
                {%- endfor -%}
              </tbody>
            </table>
            {%- if block.settings.cta_label != blank -%}
              <div class="tm-cta-wrap"><a href="{{ block.settings.cta_link | default: '#' }}" class="tm-inline-cta">{{ block.settings.cta_label }}{%- if block.settings.cta_sub != blank -%}<span class="tm-inline-cta__sub">{{ block.settings.cta_sub }}</span>{%- endif -%}</a></div>
            {%- endif -%}
          </div>
        </div>

      {%- when 'editorial' -%}
        {%- assign band_class = block.settings.band | default: 'deep-sand' -%}
        <div class="tm-band tm-band--{{ band_class }}" {{ block.shopify_attributes }}>
          <div class="tm-ed {% if block.settings.reverse %}tm-ed--reverse{% endif %}">
            <div class="tm-ed__media">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy">
              {%- endif -%}
            </div>
            <div class="tm-ed__copy">
              {%- if block.settings.eyebrow != blank -%}<p class="tm-eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
              {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
              <div class="rte">{{ block.settings.body }}</div>
            </div>
          </div>
        </div>

      {%- when 'reviews' -%}
        <div class="tm-band tm-band--espresso" {{ block.shopify_attributes }}>
          <div class="tm-reviews">
            {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
            <div class="tm-reviews__grid">
              {%- for n in (1..3) -%}
                {%- assign q = 'quote_' | append: n -%}
                {%- assign a = 'author_' | append: n -%}
                {%- if block.settings[q] != blank -%}
                  <blockquote><p>"{{ block.settings[q] }}"</p><cite>— {{ block.settings[a] }}</cite></blockquote>
                {%- endif -%}
              {%- endfor -%}
            </div>
            {%- if block.settings.cta_label != blank -%}
              <div class="tm-cta-wrap"><a href="{{ block.settings.cta_link | default: '#' }}" class="tm-inline-cta">{{ block.settings.cta_label }}{%- if block.settings.cta_sub != blank -%}<span class="tm-inline-cta__sub">{{ block.settings.cta_sub }}</span>{%- endif -%}</a></div>
            {%- endif -%}
          </div>
        </div>

      {%- when 'video' -%}
        <div class="tm-band tm-band--{{ block.settings.band | default: 'cream' }}" {{ block.shopify_attributes }}>
          <div class="tm-video">
            {%- if block.settings.eyebrow != blank -%}<p class="tm-eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
            {%- if block.settings.heading != blank -%}<h2 class="tm-h2">{{ block.settings.heading }}</h2>{%- endif -%}
            {%- if block.settings.teaser_url != blank -%}
              <div class="tm-video__wrap" data-tm-video>
                <video
                  class="tm-video__teaser"
                  src="{{ block.settings.teaser_url }}"
                  poster="{{ block.settings.poster_url }}"
                  autoplay muted loop playsinline preload="metadata"></video>
                {%- if block.settings.full_url != blank -%}
                  <button class="tm-video__play" type="button" data-tm-video-open aria-label="Play full video">
                    <svg viewBox="0 0 64 64" width="72" height="72" aria-hidden="true"><circle cx="32" cy="32" r="32" fill="rgba(42,31,16,.85)"/><path d="M26 20 L46 32 L26 44 Z" fill="#faf7f0"/></svg>
                    <span class="tm-video__play-label">Watch the full story{%- if block.settings.full_duration != blank %} <small>({{ block.settings.full_duration }})</small>{%- endif -%}</span>
                  </button>
                {%- endif -%}
              </div>
              {%- if block.settings.full_url != blank -%}
                <div class="tm-video__modal" data-tm-video-modal hidden>
                  <button class="tm-video__close" type="button" data-tm-video-close aria-label="Close video">×</button>
                  <video
                    class="tm-video__full"
                    src="{{ block.settings.full_url }}"
                    poster="{{ block.settings.poster_url }}"
                    controls playsinline preload="none"></video>
                </div>
              {%- endif -%}
              <script type="application/ld+json">
              {
                "@context": "https://schema.org",
                "@type": "VideoObject",
                "name": {{ block.settings.heading | default: product.title | json }},
                "description": {{ block.settings.description | default: product.description | strip_html | truncate: 300 | json }},
                "thumbnailUrl": {{ block.settings.poster_url | json }},
                "uploadDate": "{{ 'now' | date: '%Y-%m-%d' }}",
                "contentUrl": {{ block.settings.full_url | json }}
              }
              </script>
            {%- endif -%}
          </div>
        </div>

      {%- when 'disclaimer' -%}
        <div class="tm-band tm-band--espresso" {{ block.shopify_attributes }}>
          <div class="tm-disclaimer">
            <p>{{ block.settings.body }}</p>
          </div>
        </div>

      {%- endcase -%}
    {%- endfor -%}
  </section>
</div>

{% schema %}
{
