      {"type":"text","id":"cta_label","label":"CTA label (optional)","default":"Taste the heritage"},
      {"type":"text","id":"cta_sub","label":"CTA sublabel"},
      {"type":"url","id":"cta_link","label":"CTA link"}
    ]},
    { "type": "compare", "name": "Compare table", "settings": [
      {"type":"text","id":"heading","label":"Heading","default":"Spice Rush vs. the chai you've been buying"},
      {"type":"text","id":"us_label","label":"Us column","default":"TMolecule Spice Rush"},
      {"type":"text","id":"them_label","label":"Them column","default":"Typical Chai Latte Mix"},
      {"type":"text","id":"ico_1","label":"Row 1 icon","default":"🍬"}, {"type":"text","id":"row_1","label":"Row 1"}, {"type":"text","id":"us_1","label":"Us 1"}, {"type":"text","id":"them_1","label":"Them 1"},
      {"type":"text","id":"ico_2","label":"Row 2 icon","default":"💪"}, {"type":"text","id":"row_2","label":"Row 2"}, {"type":"text","id":"us_2","label":"Us 2"}, {"type":"text","id":"them_2","label":"Them 2"},
      {"type":"text","id":"ico_3","label":"Row 3 icon","default":"🌶️"}, {"type":"text","id":"row_3","label":"Row 3"}, {"type":"text","id":"us_3","label":"Us 3"}, {"type":"text","id":"them_3","label":"Them 3"},
      {"type":"text","id":"ico_4","label":"Row 4 icon","default":"🍃"}, {"type":"text","id":"row_4","label":"Row 4"}, {"type":"text","id":"us_4","label":"Us 4"}, {"type":"text","id":"them_4","label":"Them 4"},
      {"type":"text","id":"ico_5","label":"Row 5 icon","default":"🥑"}, {"type":"text","id":"row_5","label":"Row 5"}, {"type":"text","id":"us_5","label":"Us 5"}, {"type":"text","id":"them_5","label":"Them 5"},
      {"type":"text","id":"ico_6","label":"Row 6 icon","default":"👨‍👩‍👧"}, {"type":"text","id":"row_6","label":"Row 6"}, {"type":"text","id":"us_6","label":"Us 6"}, {"type":"text","id":"them_6","label":"Them 6"},
      {"type":"text","id":"cta_label","label":"CTA label (optional)","default":"Make the switch"},
      {"type":"text","id":"cta_sub","label":"CTA sublabel"},
      {"type":"url","id":"cta_link","label":"CTA link"}
    ]},
    { "type": "editorial", "name": "Editorial block", "settings": [
      {"type":"select","id":"band","label":"Band color","default":"deep-sand","options":[{"value":"cream","label":"Cream"},{"value":"sand","label":"Sand"},{"value":"honey","label":"Honey"},{"value":"deep-sand","label":"Deep sand"}]},
      {"type":"image_picker","id":"image","label":"Image"},
      {"type":"text","id":"eyebrow","label":"Eyebrow"},
      {"type":"text","id":"heading","label":"Heading"},
      {"type":"richtext","id":"body","label":"Body"},
      {"type":"checkbox","id":"reverse","label":"Image on right","default":false}
    ]},
    { "type": "video", "name": "Product video", "settings": [
      {"type":"select","id":"band","label":"Band color","default":"cream","options":[{"value":"cream","label":"Cream"},{"value":"sand","label":"Sand"},{"value":"honey","label":"Honey"},{"value":"deep-sand","label":"Deep sand"},{"value":"espresso","label":"Espresso"}]},
      {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Watch"},
